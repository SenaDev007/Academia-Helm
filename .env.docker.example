# ============================================================================
# EXEMPLE DE FICHIER .env POUR DOCKER COMPOSE (PRODUCTION)
# ============================================================================
# Copier vers .env et renseigner les valeurs :
#   cp .env.docker.example .env
# ============================================================================

# --- Base de données PostgreSQL ---
POSTGRES_DB=academia_hub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGER_MOT_DE_PASSE
POSTGRES_PORT=5432

# --- API (NestJS) ---
API_PORT=3000
JWT_SECRET=CHANGER_SECRET_JWT_TRES_LONG_ET_ALEATOIRE
JWT_EXPIRES_IN=7d

# --- Frontend (Next.js) - utilisées au BUILD de l'image ---
FRONTEND_PORT=3001
NEXT_PUBLIC_APP_URL=https://academia-hub.pro
NEXT_PUBLIC_BASE_DOMAIN=academia-hub.pro
NEXT_PUBLIC_API_URL=https://api.academia-hub.pro/api
