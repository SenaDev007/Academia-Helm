# =============================================================================
# .vercelignore — Optimisé pour éviter l'OOM sur Vercel
# =============================================================================
# Ne garder QUE les fichiers nécessaires au build web-app
# Tout le reste est exclu pour réduire le contexte de build (~1.2GB → ~200MB)

# ─── Autres apps du monorepo (non nécessaires au build web-app) ───
apps/api-server/
apps/desktop-app/
apps/mobile-app/
apps/migration-tools/
apps/next-app/

# ─── Répertoires dupliqués à la racine (miroirs de apps/) ───
web-app/
next-app/
api-server/

# ─── Fichiers volumineux inutiles pour le build ───
skills/
download/
upload/
database/
scripts/
scratch/
docs/
public/videos/

# ─── Fichiers système ───
node_modules/
.git/
*.log

# ─── Fichiers de build/cache ───
tsconfig.tsbuildinfo
.next/
.vercel/

# ─── Environnement ───
.env.local
.env*.local

# ─── Fichiers volumineux (vidéos, documents) ───
*.mp4
*.avi
*.mov
*.docx
*.pdf

# ─── Docker et config locale ───
docker-compose*.yml
start-dev.*
netlify.toml

