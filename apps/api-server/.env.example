DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Neon pooler: remplacer ep-xxx.neon.tech par ep-xxx-pooler.neon.tech et ajouter &pgbouncer=true
# DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require&pgbouncer=true

# ==========================================
# REDIS CACHE (Upstash) - Cache distribué
# ==========================================
# Si configuré → Redis (partagé entre instances, survit aux redémarrages)
# Si absent → cache en mémoire (local à l'instance)
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Seuil de log des requêtes lentes Prisma (ms). 0 = désactivé.
SLOW_QUERY_THRESHOLD=500

JWT_SECRET=your-secret-min-32-chars
JWT_EXPIRES_IN=7d
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://academiahelm.com
APP_PUBLIC_URL=https://academiahelm.com
APP_BASE_DOMAIN=academiahelm.com

# ==========================================
# DOMAIN MANAGEMENT - CLOUDFLARE + VERCEL
# ==========================================
# Permet la création automatique des sous-domaines d'écoles
# lors de l'onboarding (CNAME Cloudflare + Domaine Vercel + SSL)

# Cloudflare API (pour créer les CNAME DNS)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id

# Vercel API (pour ajouter les domaines au projet et émettre les certificats SSL)
VERCEL_API_TOKEN=your_vercel_api_token
VERCEL_PROJECT_ID=your_vercel_project_id
# VERCEL_TEAM_ID=your_vercel_team_id  # Optionnel — seulement si vous utilisez un team

# ==========================================
# FILE STORAGE CONFIGURATION
# ==========================================
# Options: r2 (recommandé), s3, vercel-blob, local
STORAGE_TYPE=r2

# ─── Cloudflare R2 (recommandé — S3-compatible, sans frais de sortie) ───
# 1. Créer un bucket R2 dans le dashboard Cloudflare
# 2. Créer un API Token avec permissions R2 (Object Read & Write)
# 3. Renseigner les variables ci-dessous
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_BUCKET=academahelm-docs
S3_REGION=auto
S3_ACCESS_KEY_ID=<R2_ACCESS_KEY_ID>
S3_SECRET_ACCESS_KEY=<R2_SECRET_ACCESS_KEY>
# URL publique du bucket (optionnel, via Custom Domain ou R2 Dev URL)
# S3_PUBLIC_URL=https://docs.academiahelm.com

# ─── AWS S3 (alternative — nécessite un compte AWS vérifié) ───
# STORAGE_TYPE=s3
# S3_BUCKET=academiahelm-docs
# S3_REGION=eu-west-3
# S3_ACCESS_KEY_ID=AKIA...
# S3_SECRET_ACCESS_KEY=...

# ─── Vercel Blob (alternative — gratuit, sans vérification de compte) ───
# STORAGE_TYPE=vercel-blob
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# ─── AI Configuration (Modal / OpenRouter) ───
# Clé API pour les IA intégrées (Orion, Atlas, Sara, HDIE, SCE)
# Modal (gratuit, recommandé) : créez un token sur https://modal.com/glm-5-endpoint
# OpenRouter (payant) : https://openrouter.ai
OPENROUTER_API_KEY=
# Modèle à utiliser (défaut: zai-org/GLM-5.1-FP8 — Modal GLM-5.1 FP8)
OPENROUTER_MODEL=zai-org/GLM-5.1-FP8
# URL de base (défaut: https://api.us-west-2.modal.direct/v1 pour Modal)
# Pour OpenRouter : https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=https://api.us-west-2.modal.direct/v1
# Secret webhook : copier exactement la valeur du dashboard FedaPay (sandbox ou live) pour l’URL du webhook
# FEDAPAY_WEBHOOK_SECRET=

# Dév / staging uniquement (jamais en production) — contourne la vérification de signature si le secret ne matche pas
# SKIP_WEBHOOK_SIGNATURE=false
# FEDAPAY_WEBHOOK_SKIP_VERIFY=false

# Liste publique des écoles + dropdown « Mode développement » du portail : tous les tenants si true (tests plateforme en prod)
PLATFORM_OWNER_MODE=false

# ==========================================
# EMAIL CONFIGURATION (Nodemailer / SendGrid / Resend)
# ==========================================
EMAIL_PROVIDER=resend # Options: nodemailer, sendgrid, resend, aws-ses, mock

# RESEND (Recommandé — utilisez Resend pour les emails transactionnels)
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM_NOREPLY=noreply@academiahelm.com

# SMTP (Nodemailer — alternative)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-smtp-password-or-sendgrid-api-key
SMTP_SECURE=false
SMTP_FROM=noreply@academiahelm.com

# SENDGRID (Alternative)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@academiahelm.com
SENDGRID_FROM_NAME="Academia Helm"

# ════════════════════════════════════════════════════════════════════════
# FEEXPAY — Paiements Mobile Money (Abonnements AH + Frais scolaires + Salaires)
# ════════════════════════════════════════════════════════════════════════
# Documentation : https://docs.feexpay.me
# Dashboard : https://app-v2.feexpay.me
#
# Ces credentials sont pour le compte ACADEMIA HELM (pour collecter les abonnements).
# Chaque école (tenant) configure ses propres credentials FeexPay via
# Paramètres > Paiements (stockés chiffrés en base, jamais en env).
#
# FEEXPAY_API_KEY : Token d'authentification Bearer (depuis le dashboard FeexPay)
# FEEXPAY_SHOP_ID : Identifiant public de la boutique (15 caractères, ex: nGLq7rMBFBVbpuc)
# FEEXPAY_API_URL : Base URL API (v2 par défaut)
FEEXPAY_API_KEY=your-feexpay-api-key
FEEXPAY_SHOP_ID=your-shop-id
FEEXPAY_API_URL=https://api-v2.feexpay.me

# Clé de chiffrement pour les credentials sensibles stockés en base (API keys tenants, etc.)
# Doit faire 64 caractères hexadécimaux (32 bytes). Générez avec : openssl rand -hex 32
# Si non définie, une clé dérivée de JWT_SECRET est utilisée (non recommandé en production)
CREDENTIAL_ENCRYPTION_KEY=your-64-char-hex-encryption-key-here-0000000000000000000000000000000000
