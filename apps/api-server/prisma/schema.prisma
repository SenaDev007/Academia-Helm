model UserDevice {
  id             String          @id @default(uuid())
  userId         String
  tenantId       String
  deviceHash     String          @unique
  deviceName     String?
  deviceType     String
  userAgent      String?
  ipAddress      String?
  isTrusted      Boolean         @default(false)
  lastUsedAt     DateTime?
  lastSyncAt     DateTime?      // Dernière synchronisation offline → serveur (ERP institutionnel)
  trustedAt      DateTime?
  revokedAt      DateTime?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  authAuditLogs  AuthAuditLog[]
  deviceSessions DeviceSession[]
