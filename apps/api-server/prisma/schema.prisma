  @@index([tenantId, academicYearId])
  @@map("financial_report_exports")
}

/// Sous-module 8 — Paramétrage financier (seuils, relances, clôture auto, Fedapay).
model FinancialSettings {
  id                       String   @id @default(uuid())
  tenantId                 String   @unique
  academicYearId           String?
  blockingThreshold        Decimal  @default(0) @db.Decimal(12, 2)
  allowPartialPayment      Boolean  @default(true)
  minimumInstallmentAmount Decimal? @db.Decimal(12, 2)
  autoClosureEnabled       Boolean  @default(true)
  autoClosureTime         String   @default("23:59")
  reminderWarningDays     Int      @default(3)
  reminderUrgentDays      Int      @default(7)
  reminderFinalDays        Int      @default(15)
  cancellationDelayHours  Int      @default(24)
  budgetAlertThreshold     Int      @default(85)
  expenseReceiptThreshold  Decimal? @db.Decimal(12, 2)
  fedapayEnabled           Boolean  @default(false)
  fedapayPublicKey         String?
  fedapaySecretKey         String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("financial_settings")
}

