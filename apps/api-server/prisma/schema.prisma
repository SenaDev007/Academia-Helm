  levelAuthorizations   TeacherLevelAuthorization[]
  availabilities       TeacherAvailability[]
  teachingAssignments   TeachingAssignment[]

  @@unique([tenantId, academicYearId, teacherId])
  @@index([tenantId, academicYearId])
  @@index([teacherId])
