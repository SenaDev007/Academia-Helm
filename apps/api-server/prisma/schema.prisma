  academicYearId   String
  schoolLevelId    String
  studentId        String
  cardNumber       String       @unique
  qrPayload        String
  qrHash           String
  frontImagePath   String?
  backImagePath    String?
  pdfPath          String?
  generatedAt      DateTime     @default(now())
