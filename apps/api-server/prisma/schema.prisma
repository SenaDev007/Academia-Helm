model Admission {
  id                  String       @id @default(uuid())
  tenantId            String
  academicYearId      String
  schoolLevelId       String
  firstName           String
  lastName            String
  dateOfBirth         DateTime?
  gender              String?

  // ─── Identité élève (Phase 1) ────────────────────────────────────────────
  birthPlace          String?
  nationality         String?      @default("Béninoise")
  address             String?

  // ─── Vœux académiques (Phase 1) ──────────────────────────────────────────
  requestedClassId    String?
  requestedSeriesId   String?
  wantsBilingual      Boolean      @default(false)
  previousSchool      String?

  // ─── Responsable légal (Phase 1) ─────────────────────────────────────────
  mainGuardianName    String?
  mainGuardianPhone   String?
  mainGuardianEmail   String?
  mainGuardianRelationship String?

  // ─── Traçabilité (Phase 1) ───────────────────────────────────────────────
  admissionNumber     String?      @unique
  convertedStudentId  String?
  createdByUserId     String?

  // ─── Entretien / Test (Phase 3 — réservé) ────────────────────────────────
  interviewDate       DateTime?
  testDate            DateTime?
  testScore           Float?

  // ─── Workflow existant ───────────────────────────────────────────────────
  status              String       @default("PENDING")
  applicationDate     DateTime     @default(now())
  decisionDate        DateTime?
  decisionBy          String?
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  academicYear        AcademicYear @relation(fields: [academicYearId], references: [id])
  // ⚠️ schoolLevelId référence education_levels (pas school_levels).
  // La relation @relation est SUPPRIMÉE pour éviter la FK vers la mauvaise table.
  // Voir migration 20260701110000_drop_admissions_schoollevel_fk.
  // L'ID est validé côté application (validateForeignKeys ou similaire).
  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, academicYearId, schoolLevelId])
  @@index([status])
  @@index([convertedStudentId])
  @@map("admissions")
}

