model HelmSubscription {
  id                 String                 @id @default(uuid())
  tenantId           String                 @unique
  plan               HelmPlan               @default(SEED)
  billingCycle       HelmBillingCycle       @default(MONTHLY)
  status             HelmSubscriptionStatus @default(ACTIVE)
  monthlyAmount      Int
  annualAmount       Int
  setupFee           Int
  startDate          DateTime               @default(now())
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEnd           DateTime?
  cancelledAt        DateTime?
  lastStudentCount   Int                    @default(0)
  lastCountCheckedAt DateTime?
  upgradeGraceEnd    DateTime?
  pendingUpgradePlan HelmPlan?
  activeAddons       Json                   @default("[]")
  /// Option bilingue (FR + EN) — activable depuis le module paramètres
  /// avec paiement FeexPay. Quand true, les AcademicTrack EN sont actifs.
  bilingualEnabled   Boolean                @default(false)
  fedapayCustomerId  String?
  fedapaySubId       String?
  lastPaymentDate    DateTime?
  lastPaymentAmount  Int?
  // ─── Cycle de vie abonnement (notifications + grâce + suspension) ───
  notified7DaysBefore DateTime?  // J-7 avant expiration
  notified3DaysBefore DateTime?  // J-3 avant expiration
  notified1DayBefore  DateTime?  // J-1 (24h) avant expiration
  expiredAt           DateTime?  // Jour 0 — expiration silencieuse
  gracePeriodEnd      DateTime?  // J+7 — fin période de grâce → suspension
  suspendedAt         DateTime?  // J+7 — suspension (lecture seule)
  blockedAt           DateTime?  // J+37 — blocage définitif
  notifiedBlockWarning DateTime? // J+23 — notification "blocage dans 7 jours"
  reactivationFee     Int        @default(5000) // Frais de réactivation (FCFA)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  invoices           HelmInvoice[]
  tenant             Tenant                 @relation(fields: [tenantId], references: [id])
  upgradeHistory     HelmUpgradeEvent[]

  @@index([tenantId])
  @@index([status])
  @@index([plan])
}

