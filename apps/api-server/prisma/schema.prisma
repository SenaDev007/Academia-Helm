  studentFees    StudentFee[]

  @@index([tenantId, academicYearId, schoolLevelId])
  @@index([feeCategoryId])
  @@map("fee_definitions")
}

/// Sous-module 1 — Types de frais (spec institutionnelle).
enum FeeType {
  INSCRIPTION
  REINSCRIPTION
  TUITION
  ANNEX
  EXCEPTIONAL
}

/// Sous-module 1 — Configuration des frais (spec institutionnelle). Priorité: Classe > Niveau > Override.
model FeeStructure {
  id               String                  @id @default(uuid())
  tenantId         String
  academicYearId   String
  levelId          String?
  classId          String?
  name             String
  feeType          FeeType
  totalAmount      Decimal                 @db.Decimal(10, 2)
  isInstallment    Boolean                 @default(false)
  isMandatory      Boolean                 @default(true)
  isActive         Boolean                 @default(true)
  createdById      String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  academicYear     AcademicYear           @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class            Class?                  @relation("FeeStructureClass", fields: [classId], references: [id], onDelete: SetNull)
  creator          User?                   @relation("FeeStructureCreator", fields: [createdById], references: [id], onDelete: SetNull)
  level            SchoolLevel?            @relation("FeeStructureLevel", fields: [levelId], references: [id], onDelete: SetNull)
  tenant           Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  structureInstallments FeeStructureInstallment[]
  overrides        FeeOverride[]
  accountBreakdowns AccountBreakdown[]

  @@index([tenantId, academicYearId])
  @@index([levelId])
  @@index([classId])
  @@index([feeType])
  @@map("fee_structures")
}

model FeeStructureInstallment {
  id               String        @id @default(uuid())
  feeStructureId   String
  label            String
  amount           Decimal       @db.Decimal(10, 2)
  dueDate          DateTime      @db.Date
  orderIndex       Int
  feeStructure     FeeStructure  @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)

  @@index([feeStructureId])
  @@map("fee_structure_installments")
}

/// Personnalisation élève (réduction, cas social). Justification obligatoire, audit, ORION.
model FeeOverride {
  id               String       @id @default(uuid())
  feeStructureId   String
  studentId        String
  customAmount    Decimal      @db.Decimal(10, 2)
  reason           String
  createdById      String?
  createdAt        DateTime     @default(now())
  creator          User?        @relation("FeeOverrideCreator", fields: [createdById], references: [id], onDelete: SetNull)
  feeStructure     FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  student          Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([feeStructureId])
  @@index([studentId])
  @@map("fee_overrides")
}

model FeeRegime {
  id             String              @id @default(uuid())
