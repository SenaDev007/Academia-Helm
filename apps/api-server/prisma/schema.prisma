generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "partialIndexes"]
}

datasource db {
  provider   = "postgresql"
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "public")]
}

