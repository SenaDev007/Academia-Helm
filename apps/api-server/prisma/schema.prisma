// ============================================================================
// SUBSCRIPTION SYSTEM - SOUSCRIPTION VERROUILLÉE
// ============================================================================

enum SubscriptionStatus {
  TRIAL_ACTIVE
  ACTIVE
  GRACE
  SUSPENDED
  CANCELLED
  DEV_ACTIVE
}

enum BillingEventType {
  INITIAL_SUBSCRIPTION
  RENEWAL
  MANUAL_PAYMENT
  ADJUSTMENT
}

model SubscriptionPlan {
  id               String         @id @default(uuid())
  code             String         @unique
  name             String
  monthlyPrice     Int            @map("monthly_price")
  yearlyPrice      Int            @map("yearly_price")
  maxSchools       Int            @default(1) @map("max_schools")
  bilingualAllowed Boolean        @default(false) @map("bilingual_allowed")
  createdAt        DateTime       @default(now()) @map("created_at")
  Subscription     Subscription[]

  @@map("subscription_plans")
}

model BillingEvent {
  id             String           @id @default(uuid())
  tenantId       String           @map("tenant_id")
  subscriptionId String?          @map("subscription_id")
  type           BillingEventType
  amount         Int
  channel        String
  reference      String?
  metadata       Json?
  createdAt      DateTime         @default(now()) @map("created_at")

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([tenantId])
  @@index([type])
  @@index([createdAt])
  @@map("billing_events")
}

// ============================================================================
// ONBOARDING SYSTEM - ONBOARDING ÉCOLE
// ============================================================================

model OnboardingDraft {
  id                 String  @id @default(uuid())
  schoolName         String  @map("school_name")
  schoolType         String  @map("school_type")
  city               String
  country            String
  phone              String
  email              String
  bilingual          Boolean @default(false)
  schoolsCount       Int     @default(1) @map("schools_count")
  preferredSubdomain String? @map("preferred_subdomain")

  promoterFirstName    String? @map("promoter_first_name")
  promoterLastName     String? @map("promoter_last_name")
  promoterEmail        String? @map("promoter_email")
  promoterPhone        String? @map("promoter_phone")
  promoterPasswordHash String? @map("promoter_password_hash")
  otpVerified          Boolean @default(false) @map("otp_verified")

  selectedPlanId String? @map("selected_plan_id")
  priceSnapshot  Json?   @map("price_snapshot")

  status String @default("DRAFT")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payments OnboardingPayment[]
  otps     OnboardingOTP[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("onboarding_drafts")
}

model OnboardingPayment {
  id        String   @id @default(uuid())
  draftId   String   @map("draft_id")
  provider  String   @default("fedapay")
  reference String   @unique
  amount    Int
  currency  String   @default("XOF")
  status    String   @default("PENDING")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  draft OnboardingDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
  @@index([reference])
  @@index([status])
  @@map("onboarding_payments")
}

// ============================================================================
// ONBOARDING OTP - VALIDATION TÉLÉPHONE PROMOTEUR
// ============================================================================

model OnboardingOTP {
  id        String   @id @default(uuid())
  draftId   String   @map("draft_id")
  phone     String
  code      String   // Code OTP (6 chiffres)
  expiresAt DateTime @map("expires_at") // Expiration après 3 minutes
  verified  Boolean  @default(false)
  verifiedAt DateTime? @map("verified_at")
  createdAt DateTime @default(now()) @map("created_at")

  draft OnboardingDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
  @@index([phone])
  @@index([code])
  @@index([expiresAt])
  @@map("onboarding_otps")
}

// ============================================================================
// PAYMENT WEBHOOK LOG - IDEMPOTENCE WEBHOOKS
// ============================================================================

model PaymentWebhookLog {
  id          String    @id @default(uuid())
  reference   String    @unique
  provider    String    @default("fedapay")
  eventType   String    @map("event_type")
  processed   Boolean   @default(false)
  processedAt DateTime? @map("processed_at")
  payload     Json?
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([reference])
  @@index([processed])
  @@index([createdAt])
  @@map("payment_webhook_logs")
}

// ============================================================================
// BILLING REMINDER LOG - AUDIT RAPPELS AUTOMATIQUES
// ============================================================================

model BillingReminderLog {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  subscriptionId String   @map("subscription_id")
  reminderType   String   @map("reminder_type") // J-7, J-3, J-1
  daysRemaining  Int      @map("days_remaining")
  sentAt         DateTime @default(now()) @map("sent_at")
  channels       Json // { sms: boolean, email: boolean, whatsapp: boolean }
  success        Boolean  @default(true)
  errorMessage   String?  @map("error_message")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, reminderType, daysRemaining])
  @@index([tenantId])
  @@index([subscriptionId])
  @@index([reminderType])
  @@index([sentAt])
  @@index([success])
  @@map("billing_reminder_logs")
}

// ============================================================================
// PRICING CONFIG - CONFIGURATION PRICING PARAMÉTRABLE
// ============================================================================

model PricingConfig {
  id                     String   @id @default(uuid())
  initialSubscriptionFee Int      @map("initial_subscription_fee") // 100 000 FCFA
  multiSchoolInitialDiscountPercent Int? @map("multi_school_initial_discount_percent") // 10% de réduction sur la souscription initiale pour les promoteurs gérant plusieurs écoles
  monthlyBasePrice       Int      @map("monthly_base_price") // 15 000 FCFA
  yearlyBasePrice        Int      @map("yearly_base_price") // 150 000 FCFA
  yearlyDiscountPercent  Int      @map("yearly_discount_percent") // 17%
  bilingualMonthlyAddon  Int      @map("bilingual_monthly_addon") // 5 000 FCFA
  bilingualYearlyAddon   Int      @map("bilingual_yearly_addon") // 50 000 FCFA
  schoolAdditionalPrice  Int      @map("school_additional_price") // 10 000 FCFA par école supplémentaire
  trialDays              Int      @default(30) @map("trial_days")
  graceDays              Int      @default(7) @map("grace_days")
  reminderDays           Json     @map("reminder_days") // [7, 3, 1] pour J-7, J-3, J-1
  currency               String   @default("XOF")
  isActive               Boolean  @default(false) @map("is_active")
  version                Int      @default(1)
  createdAt              DateTime @default(now()) @map("created_at")
  createdBy              String?  @map("created_by")
  metadata               Json?

  @@unique([version])
  @@index([isActive])
  @@index([version])
  @@index([createdAt])
  @@map("pricing_configs")
}

model PricingGroupTier {
  id           String   @id @default(uuid())
  schoolsCount Int      @unique @map("schools_count")
  monthlyPrice Int      @map("monthly_price")
  yearlyPrice  Int      @map("yearly_price")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdBy    String?  @map("created_by")
  metadata     Json?

  @@index([schoolsCount])
  @@index([isActive])
  @@map("pricing_group_tiers")
}

model PricingOverride {
  id              String    @id @default(uuid())
  tenantId        String?   @map("tenant_id")
  code            String?   @unique // Code promo (ex: "PROMO2024")
  percentDiscount Int?      @map("percent_discount")
  fixedPrice      Int?      @map("fixed_price")
  expiresAt       DateTime? @map("expires_at")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  createdBy       String?   @map("created_by")
  metadata        Json?

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([code])
  @@index([isActive])
  @@index([expiresAt])
  @@map("pricing_overrides")
}
