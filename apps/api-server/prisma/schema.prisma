// ============================================================================
// MODULE : IMPÔTS ET ÉTATS FINANCIERS (remplace l'onglet CNSS)
// ============================================================================
// 4 sous-onglets : Tableau de bord → Gestion du personnel → États financiers → Déclarations fiscales
// Tous les taux (CNSS, IST, AIB) sont configurables via TaxSettings.
// ============================================================================

// ─── Paramètres fiscaux configurables (taux, seuils) ───────────────────────
model TaxSettings {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  academicYearId  String?

  // Taux CNSS (%) — part patronale + ouvrière
  cnssFamilialesRate    Float @default(9.0)   // Cotisations familiales
  cnssRisquesRate       Float @default(1.0)   // Risques professionnels
  cnssVieillesseRate    Float @default(0.0)   // Assurance vieillesse (à valider)
  cnssPatronaleRate     Float @default(6.4)   // Part patronale
  cnssOuvriereRate      Float @default(3.6)   // Part ouvrière

  // Taux IST (%)
  istVpsRate            Float @default(4.0)   // Versement Patronal sur Salaires (VPS)
  istIrppRate           Float @default(0.0)   // IRPP (barème progressif, 0 = calcul auto)

  // Taux AIB (%)
  aibAchatsRate         Float @default(1.0)   // AIB sur achats de marchandises
  aibPrestationsRate    Float @default(5.0)   // AIB sur prestations de services

  // Périodicité
  istFrequency          String @default("MONTHLY") // MONTHLY, QUARTERLY
  cnssFrequency         String @default("QUARTERLY")
  aibFrequency          String @default("MONTHLY")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tax_settings")
}

// ─── États financiers SYSCOHADA (Bilan, CR, TFT) ───────────────────────────
model FinancialStatement {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId  String
  type            String   // BILAN_ACTIF, BILAN_PASSIF, COMPTE_RESULTAT, TFT
  lineCode        String   // AD, AE, BZ, CA, TA... (codes SYSCOHADA)
  lineLabel       String
  note            String?  // référence note annexe (ex: "3", "18")
  amountN         Decimal  @default(0) @db.Decimal(18, 2)
  amountN1        Decimal? @db.Decimal(18, 2)
  category        String?  // IMMOBILISATIONS, CIRCULANT, TRESORERIE...
  isSubtotal      Boolean  @default(false)
  isTotal         Boolean  @default(false)
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, academicYearId, type, lineCode])
  @@index([tenantId, academicYearId, type])
  @@map("financial_statements")
}

// ─── Notes annexes (36 notes SYSCOHADA) ────────────────────────────────────
model FinancialNote {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId  String
  noteCode        String   // NOTE 1, NOTE 18, NOTE 27A...
  noteTitle       String
  lineLabel       String
  amountN         Decimal  @default(0) @db.Decimal(18, 2)
  amountN1        Decimal? @db.Decimal(18, 2)
  metadata        Json?    // colonnes spécifiques (hypothèques, nantissements, échéances...)
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, academicYearId, noteCode])
  @@map("financial_notes")
}

// ─── Déclarations fiscales (IST, AIB, CNSS) ────────────────────────────────
model TaxDeclaration {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId  String
  type            String   // IST, AIB, CNSS
  period          String   // "2026-01", "2026-T1", "2026"
  status          String   @default("DRAFT") // DRAFT, SUBMITTED, PAID
  data            Json     // données structurées (lignes, calculs, détails)
  totalAmount     Decimal  @default(0) @db.Decimal(18, 2)
  submittedAt     DateTime?
  paidAt          DateTime?
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, academicYearId, type, period])
  @@index([tenantId, academicYearId, type])
  @@map("tax_declarations")
}

// ─── Fiches de renseignements (Page garde + R1-R4) ────────────────────────
model FinancialReportHeader {
  id                String   @id @default(uuid())
  tenantId          String
  academicYearId    String

  // Page de garde
  centreDepot       String?
  denominationSociale String?
  sigleUsuel        String?
  exerciceClosLe    String?
  dureeExerciceMois Int?

  // FICHE R1 — Identification
  adresse           String?
  numeroIF          String?
  greffe            String?
  numeroRC          String?
  numeroCCSS        String?
  numeroTelephone   String?
  adresseGeoComplete String?
  // ZE-ZH: autres infos R1
  formeJuridique    String?
  capitalSocial     String?
  nombreEmployes    Int?
  referentielBancaire String?

  // FICHE R2 — Activité
  regimeFiscal      String?
  paysSiegeSocial   String?
  nbEtablissementsPays Int?
  nbEtablissementsHorsPays Int?
  premiereAnneeExercice String?
  activiteDesignation String?
  activiteLocalisation String?
  nbSalaries        Int?
  chiffreAffaires   Decimal? @db.Decimal(18, 2)
  partsMarche       String?
  exportations      String?

  // FICHE R3 — Dirigeants et Conseil d'Administration (JSON)
  dirigeants        Json?    // [{nom, prenom, qualite, numeroIF, adresse}]
  membresConseil    Json?    // [{nom, prenom, qualite, adresse}]
  commissairesComptes Json?  // [{nom, prenom, adresse}]

  // FICHE R4 — Notes applicables (JSON array de codes)
  notesApplicables  Json?    // [{code: "NOTE 1", applicable: true}]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, academicYearId])
  @@map("financial_report_headers")
}

// ─── États de paiement et fiches de paie (module taxes) ───────────────────
model TaxPayrollPeriod {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId  String
  period          String   // "2026-01" (YYYY-MM)
  staffType       String   // PERMANENT, VACATAIRE
  status          String   @default("DRAFT") // DRAFT, FINALIZED
  totalGross       Decimal  @default(0) @db.Decimal(18, 2)
  totalDeductions  Decimal  @default(0) @db.Decimal(18, 2)
  totalNet         Decimal  @default(0) @db.Decimal(18, 2)

  payslips        TaxPayslip[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, academicYearId, period, staffType])
  @@map("tax_payroll_periods")
}

model TaxPayslip {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId  String
  staffId         String
  payrollPeriodId String
  period          String

  // Rubriques (du fichier Excel "Fiche de paie")
  salaireBase     Decimal  @default(0) @db.Decimal(18, 2)
  moinsPercesArriere Decimal @default(0) @db.Decimal(18, 2)
  gratificationsEtrennes Decimal @default(0) @db.Decimal(18, 2)
  indemnites      Decimal  @default(0) @db.Decimal(18, 2)
  primeSalissures Decimal  @default(0) @db.Decimal(18, 2)
  salaireBrut     Decimal  @default(0) @db.Decimal(18, 2)

  // Retenues
  cnssOuvriere    Decimal  @default(0) @db.Decimal(18, 2)
  itsNet          Decimal  @default(0) @db.Decimal(18, 2)
  irppNet         Decimal  @default(0) @db.Decimal(18, 2)
  avanceAcompte   Decimal  @default(0) @db.Decimal(18, 2)
  opposition      Decimal  @default(0) @db.Decimal(18, 2)
  taxesRadioTele  Decimal  @default(0) @db.Decimal(18, 2)

  // Calculé
  totalRetenues   Decimal  @default(0) @db.Decimal(18, 2)
  netAPayer       Decimal  @default(0) @db.Decimal(18, 2)

  // CNSS patronale (info)
  cnssPatronale   Decimal  @default(0) @db.Decimal(18, 2)
  vps             Decimal  @default(0) @db.Decimal(18, 2)

  status          String   @default("DRAFT")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrollPeriod   TaxPayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)

  @@index([tenantId, academicYearId, period])
  @@map("tax_payslips")
}

// ============================================================================
// TENANT WEBSITE — Site institutionnel intelligent par école
// ============================================================================

/// Configuration globale du site institutionnel d'un tenant.
/// Un seul enregistrement par tenant (tenantId @unique).
model TenantWebsite {
  id                   String   @id @default(uuid())
  tenantId             String   @unique
  // Hero Banner
  heroTitle            String?  @db.Text
  heroSubtitle         String?  @db.Text
  heroImageUrl         String?
  heroCtaText          String?  @default("Pré-inscription")
  heroCtaUrl           String?  @default("/public/pre-enrollment")
  heroIsActive         Boolean  @default(true)
  // Chiffres clés (JSON array: [{label, value, icon}])
  keyFigures           Json     @default("[]")
  // Mot du Promoteur
  promoterWord         String?  @db.Text
  promoterName         String?
  promoterPhotoUrl     String?
  promoterIsActive     Boolean  @default(true)
  // Mot du Directeur
  directorWord         String?  @db.Text
  directorName         String?
  directorPhotoUrl     String?
  directorIsActive     Boolean  @default(true)
  // Présentation
  presentationTitle    String?
  presentationContent  String?  @db.Text
  presentationImageUrl String?
  presentationIsActive Boolean  @default(true)
  // Admissions
  admissionsTitle      String?
  admissionsContent    String?  @db.Text
  admissionsIsActive   Boolean  @default(true)
  // Vie scolaire
  schoolLifeTitle      String?
  schoolLifeContent    String?  @db.Text
  schoolLifeIsActive   Boolean  @default(true)
  // Footer
  footerAboutText     String?  @db.Text
  footerCopyrightText String?
  footerIsActive      Boolean  @default(true)
  // Réseaux sociaux (JSON: {facebook, twitter, instagram, linkedin, youtube, whatsapp, telegram})
  socialLinks         Json     @default("{}")
  // SEO
  seoMetaTitle        String?
  seoMetaDescription  String?  @db.Text
  seoKeywords         String?
  seoOgImageUrl       String?
  // Contact
  contactEmail        String?
  contactPhone        String?
  contactAddress      String?
  contactMapUrl       String?
  // Identité visuelle — palette de couleurs personnalisée (1-4 couleurs)
  // Format JSON: [{ "name": "Primaire", "value": "#0b2f73" }, { "name": "Accent", "value": "#f5b335" }]
  // Si vide/null → utilise la palette Helm par défaut (Navy/Blue/Gold)
  customColors        Json?
  // Paramètres
  isActive            Boolean  @default(true)
  // IA
  aiEnabled           Boolean  @default(false)
  aiWelcomeMessage    String?  @db.Text
  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  newsArticles        TenantNewsArticle[]
  events              TenantEvent[]
  galleryItems        TenantGalleryItem[]
  testimonials        TenantTestimonial[]
  faqItems            TenantFaqItem[]
  contactMessages     TenantContactMessage[]
  levelSections       TenantWebsiteLevelSection[]

  @@map("tenant_websites")
}

/**
 * Section de site institutionnel spécifique à un niveau scolaire.
 *
 * Permet d'avoir du contenu différent par niveau (maternelle, primaire, secondaire) :
 *   - Mot du directeur spécifique au niveau
 *   - Présentation spécifique au niveau
 *   - Section admissions spécifique au niveau
 *   - Section vie scolaire spécifique au niveau
 *
 * Si aucune section niveau-spécifique n'existe → fallback sur TenantWebsite global.
 */
model TenantWebsiteLevelSection {
  id                   String   @id @default(uuid())
  tenantId             String
  websiteId            String
  schoolLevelId        String
  // Contenu spécifique au niveau (null = fallback sur TenantWebsite global)
  directorWord         String?  @db.Text
  directorName         String?
  directorPhotoUrl     String?
  directorIsActive     Boolean?
  presentationTitle    String?
  presentationContent  String?  @db.Text
  presentationIsActive Boolean?
  admissionsTitle      String?
  admissionsContent    String?  @db.Text
  admissionsIsActive   Boolean?
  schoolLifeTitle      String?
  schoolLifeContent    String?  @db.Text
  schoolLifeIsActive   Boolean?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  website              TenantWebsite @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  tenant               Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schoolLevel          SchoolLevel   @relation(fields: [schoolLevelId], references: [id], onDelete: Cascade)

  @@unique([tenantId, schoolLevelId])
  @@index([tenantId, schoolLevelId])
  @@map("tenant_website_level_sections")
}

/// Article d'actualité du site institutionnel d'un tenant.
model TenantNewsArticle {
  id          String   @id @default(uuid())
  tenantId    String
  websiteId   String?
  title       String
  slug        String
  excerpt     String?  @db.Text
  content     String   @db.Text
  coverImageUrl String?
  category    String?
  tags        String[]
  status      String   @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  publishedAt DateTime?
  isFeatured  Boolean  @default(false)
  viewCount   Int      @default(0)
  seoTitle    String?
  seoDescription String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  website     TenantWebsite? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId, status, publishedAt])
  @@index([tenantId, category])
  @@map("tenant_news_articles")
}

/// Événement d'agenda du site institutionnel d'un tenant.
model TenantEvent {
  id          String   @id @default(uuid())
  tenantId    String
  websiteId   String?
  title       String
  description String?  @db.Text
  startDate   DateTime
  endDate     DateTime?
  location    String?
  imageUrl    String?
  category    String?
  status      String   @default("UPCOMING") // UPCOMING | ONGOING | COMPLETED | CANCELLED
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  website     TenantWebsite? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, startDate])
  @@index([tenantId, status])
  @@map("tenant_events")
}

/// Élément de galerie photo du site institutionnel d'un tenant.
model TenantGalleryItem {
  id          String   @id @default(uuid())
  tenantId    String
  websiteId   String?
  imageUrl    String
  thumbnailUrl String?
  caption     String?
  category    String?
  displayOrder Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  website     TenantWebsite? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive, displayOrder])
  @@index([tenantId, category])
  @@map("tenant_gallery_items")
}

/// Témoignage sur le site institutionnel d'un tenant.
model TenantTestimonial {
  id          String   @id @default(uuid())
  tenantId    String
  websiteId   String?
  authorName  String
  authorRole  String?  // ex: "Parent d'élève", "Ancien élève", "Enseignant"
  authorPhotoUrl String?
  content     String   @db.Text
  rating      Int?     // 1-5
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  website     TenantWebsite? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive, displayOrder])
  @@map("tenant_testimonials")
}

/// Question/réponse FAQ du site institutionnel d'un tenant.
model TenantFaqItem {
  id          String   @id @default(uuid())
  tenantId    String
  websiteId   String?
  question    String
  answer      String   @db.Text
  category    String?
  displayOrder Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  website     TenantWebsite? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive, displayOrder])
  @@index([tenantId, category])
  @@map("tenant_faq_items")
}

/// Message de contact reçu via le site institutionnel d'un tenant.
model TenantContactMessage {
  id          String   @id @default(uuid())
  tenantId    String
  websiteId   String?
  name        String
  email       String
  phone       String?
  subject     String?
  message     String   @db.Text
  status      String   @default("NEW") // NEW | READ | REPLIED | ARCHIVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  website     TenantWebsite? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt])
  @@map("tenant_contact_messages")
}
