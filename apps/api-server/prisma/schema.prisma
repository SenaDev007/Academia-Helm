/// Trois identifiants distincts : (1) matricule Academia Helm = interne établissement ; (2) NPI = identification personnelle Bénin ; (3) numéro Educmaster = identifiant plateforme MEMP — aucun n'est équivalent à l'autre.
model Student {
  id                       String                       @id @default(uuid())
  tenantId                 String
  academicYearId           String
  currentAcademicYearId    String?
  schoolLevelId            String
  studentCode              String?                     // Legacy / affichage; préférer matricule
  matricule                String?                     // 1) Matricule Academia Helm : identifiant interne établissement, généré backend, immuable. Distinct du NPI et du numéro Educmaster.
  enrollmentYear           Int?                        // Année d'inscription initiale (pour traçabilité matricule)
  firstName                String
  lastName                 String
  dateOfBirth              DateTime?
  gender                   String?
  nationality              String?
  primaryLanguage          String?
