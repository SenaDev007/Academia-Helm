/// ============================================================================
/// MODÈLE `Class` — SECTION PHYSIQUE RÉELLE (subdivision A/B/C d'une classe)
/// ============================================================================
/// ARCHITECTURE 3 COUCHES — ne pas confondre :
///
///   1. `Classroom` (table `classrooms`) : déclaration annuelle d'une classe
///      par grade (Paramètres > Structure > « Classe officielle par année »).
///      Liée à `EducationGrade` via `gradeId`.
///
///   2. `AcademicClass` (table `pedagogy_academic_classes`) : abstraction
///      pédagogique synchronisée automatiquement depuis `Classroom`. Utilisée
///      par Matière & Programme, Emplois du temps. Liée à `AcademicLevel` et
///      `AcademicCycle`.
///
///   3. `Class` (table `classes`, CE MODÈLE) : section physique réelle d'une
///      `AcademicClass`. Exemples : « CE1 A », « CE1 B », « 6ème 1 ».
///      Utilisée par Élèves (inscriptions), Bulletins, Affectation enseignants,
///      Présences, etc. Liée à `AcademicClass` via `officialClassId`.
///
/// INVARIANT : chaque `AcademicClass` active a TOUJOURS au moins une section
/// `Class` (créée automatiquement par `syncClassSectionsFromAcademicClasses()`
/// dans academic-structure-prisma.service.ts).
///
/// Pour les écoles avec une seule section par classe (cas Eveil d'Afrique),
/// une section par défaut sans suffixe est créée. Les écoles avec plusieurs
/// sections peuvent en ajouter via l'UI « Sections par classe » (Paramètres).
/// ============================================================================
model Class {
  id                         String                      @id @default(uuid())
  tenantId                   String
  academicYearId             String
  schoolLevelId              String
  academicTrackId            String?
  /// Lien vers la classe officielle (AcademicClass) dans le module Pédagogie
  /// Ex: CI/A → officialClassId = AcademicClass "CI"
  officialClassId            String?
  language                   String?
  name                       String
  code                       String
  capacity                   Int?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  absences                   Absence[]
  announcements              Announcement[]
  annualTeacherSupplies      AnnualTeacherSupply[]       @relation("AnnualTeacherSupplyClass")
  attendanceRecords          AttendanceRecord[]
  canteenEnrollments         CanteenEnrollment[]         @relation("CanteenEnrollmentClass")
  classCouncils              ClassCouncil[]
  classStudents              ClassStudent[]
  classSubjects              ClassSubject[]
  classTransfersFrom         ClassTransfer[]             @relation("ClassTransfersFrom")
  classTransfersTo           ClassTransfer[]             @relation("ClassTransfersTo")
  academicTrack              AcademicTrack?              @relation(fields: [academicTrackId], references: [id])
  /// Classe officielle (AcademicClass) dont cette classe physique découle
  officialClass              AcademicClass?              @relation("PhysicalClassOfficialClass", fields: [officialClassId], references: [id], onDelete: SetNull)
  academicYear               AcademicYear                @relation(fields: [academicYearId], references: [id])
  schoolLevel                SchoolLevel                 @relation(fields: [schoolLevelId], references: [id])
  tenant                     Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dailyLogs                  DailyLog[]
  /// Affectations enseignants pour cette classe physique
  teacherClassAssignments    TeacherClassAssignment[]    @relation("TeacherClassAssignmentPhysicalClass")
  educastAccesses            EducastAccess[]             @relation("EducastAccessClass")
  educastContents            EducastContent[]            @relation("EducastContentClass")
  feeConfigurations          FeeConfiguration[]
  feeDefinitions             FeeDefinition[]             @relation("FeeDefinitionClass")
  feeStructures              FeeStructure[]              @relation("FeeStructureClass")
  homeworkEntries            HomeworkEntry[]
  honorRolls                 HonorRoll[]
  incidents                  Incident[]
  infirmaryEmergencies       InfirmaryEmergency[]        @relation("InfirmaryEmergencyClass")
  infirmaryVisits            InfirmaryVisit[]            @relation("InfirmaryVisitClass")
  lessonJournals             LessonJournal[]
  lessonPlanAssignments      LessonPlanAssignment[]
  lessonPlans                LessonPlan[]
  materialStocks             MaterialStock[]             @relation("MaterialStockClass")
  meetings                   Meeting[]                   @relation("MeetingClass")
  pedagogicalDocuments       PedagogicalDocument[]
  pedagogicalSheets          PedagogicalSheet[]
  rankings                   Ranking[]
  staffAssignments           StaffAssignment[]
  studentAcademicRecords     StudentAcademicRecord[]     @relation("StudentAcademicRecordClass")
  studentEnrollments         StudentEnrollment[]
  subjectAssignments         SubjectAssignment[]
  teacherMaterialAssignments TeacherMaterialAssignment[] @relation("TeacherMaterialAssignmentClass")
  timetableEntries           TimetableEntry[]
  evaluations              Evaluation[]
  gradeValidationBatches   GradeValidationBatch[]
  gradeLocks               GradeLock[]
  studentPeriodAverages    StudentPeriodAverage[]
  studentSubjectAverages   StudentSubjectAverage[]
  institutionalGrades      Grade[]

  @@unique([tenantId, academicYearId, code])
  @@index([tenantId, academicYearId, schoolLevelId])
  @@map("classes")
}

