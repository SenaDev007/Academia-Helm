/// Annulation = écriture inverse (REVERSAL), jamais suppression. reversedFromId pointe vers le paiement annulé.
model Payment {
  id                 String                @id @default(uuid())
  tenantId           String
  academicYearId     String?
  studentId          String
  schoolLevelId      String
  feeConfigurationId String?
  amount             Decimal               @db.Decimal(10, 2)
  paymentMethod      String?
  paymentDate        DateTime              @db.Date
  reference          String?
  receiptNumber      String?
  status             String                @default("completed")
  paymentFlowId      String?
  notes              String?
  createdBy          String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  studentFeeId       String?
  transactionType    String                @default("PAYMENT")
  reversedFromId    String?
  reversalReason     String?
  paymentAllocations PaymentAllocation[]
  notifications      PaymentNotification[]
  receipt            PaymentReceipt?
  academicYear       AcademicYear?         @relation(fields: [academicYearId], references: [id])
  creator            User?                 @relation(fields: [createdBy], references: [id])
  feeConfiguration   FeeConfiguration?     @relation(fields: [feeConfigurationId], references: [id])
  paymentFlow        PaymentFlow?          @relation("PaymentPaymentFlow", fields: [paymentFlowId], references: [id])
  schoolLevel        SchoolLevel           @relation(fields: [schoolLevelId], references: [id])
  studentFee         StudentFee?           @relation("StudentFeePayment", fields: [studentFeeId], references: [id])
  student            Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reversedFrom       Payment?              @relation("PaymentReversal", fields: [reversedFromId], references: [id])
  reversals          Payment[]             @relation("PaymentReversal")

  @@index([tenantId, schoolLevelId])
  @@index([studentId])
  @@index([studentFeeId])
  @@index([transactionType])
  @@index([reversedFromId])
  @@map("payments")
}

model PaymentFlow {
  id                  String                @id @default(uuid())
  tenantId            String
  flowType            String
  destination         String
  amount              Float
  currency            String                @default("XOF")
  status              String
  pspReference        String?
