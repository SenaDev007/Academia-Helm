  @@index([tenantId])
  @@index([deviceId])
  @@index([sessionId])
  @@index([action])
  @@index([status])
  @@index([createdAt])
  @@index([userId, tenantId])
  @@map("auth_audit_logs")
}

/// Événements de sécurité (SIEM simple) : login échoués, sync anormale, multi-device suspect, etc.
model SecurityEvent {
  id         String   @id @default(uuid())
  tenantId  String?
  userId    String?
  eventType String   // LOGIN_FAILED, SYNC_CONFLICT, SYNC_ANOMALY, DEVICE_REVOKED, etc.
  severity  String   // LOW, MEDIUM, HIGH, CRITICAL
  ipAddress String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("security_events")
}

model Role {
  id              String           @id @default(uuid())
  tenantId        String?
  name            String
  description     String?
  isSystemRole    Boolean          @default(false)

  // Accès IA
  canAccessOrion  Boolean          @default(false)
  canAccessAtlas  Boolean          @default(false)

  // Niveaux autorisés (vide = tous)
  allowedLevelIds String[]         @default([])

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]

  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  resource        String
  action          String
  description     String?
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String
  roleId    String
  tenantId  String?   // Contexte tenant pour isolation stricte (null = rôle plateforme)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([tenantId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String
  levelScope   String?    // Niveau scolaire optionnel (scope de la permission)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model School {
  id                       String                    @id @default(uuid())
