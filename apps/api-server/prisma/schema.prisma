// ============================================================================
// IDENTITÉ ÉTABLISSEMENT — SOURCE LÉGALE DE VÉRITÉ VERSIONNÉE
// ============================================================================
// Chaque modification crée une nouvelle version.
// Les documents historiques conservent leur validité légale.
// Un seul profil actif par tenant, mais toutes les versions sont conservées.

model TenantIdentityProfile {
  id                    String    @id @default(uuid())
  tenantId              String
  version               Int       @default(1)
  isActive              Boolean   @default(false)

  // Identité juridique
  schoolName            String
  schoolAcronym         String?
  schoolType            String    @default("PRIVEE") // PUBLIQUE, PRIVEE, CONFESSIONNELLE, INSTITUT, UNIVERSITE
  authorizationNumber   String?
  foundationDate        DateTime?
  slogan                String?

  // Localisation
  address               String?
  city                  String?
  department            String?
  country               String    @default("BJ")
  postalCode            String?

  // Contacts
  phonePrimary          String?
  phoneSecondary        String?
  email                 String?
  website               String?

  // Paramètres régionaux
  currency              String    @default("XOF")
  timezone              String    @default("Africa/Porto-Novo")

  // Visuels officiels (URLs des fichiers uploadés)
  logoUrl               String?
  stampUrl              String?
  directorSignatureUrl  String?

  // Métadonnées de version
  createdBy             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  activatedAt           DateTime?
  activatedBy           String?
  deactivatedAt         DateTime?
  deactivatedBy         String?
  changeReason          String?

  // Relations
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, version])
  @@index([tenantId, isActive])
  @@index([tenantId, version])
  @@map("tenant_identity_profiles")
}

// Cachets et signatures générés par tenant et par niveau scolaire (Paramètres → Cachets)
// Un niveau null = cachet global (tout l'établissement). Sinon un set de cachets par niveau.
// Compound unique : where { tenantId_educationLevelId: { tenantId, educationLevelId } }
model TenantStamp {
  id                   String          @id @default(uuid())
  tenantId             String
  educationLevelId     String?         // null = global établissement
  circularStampUrl     String?
  rectangularStampUrl  String?
  ovalStampUrl         String?
  generatedAt          DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  educationLevel       EducationLevel? @relation(fields: [educationLevelId], references: [id], onDelete: Cascade)
  @@unique([tenantId, educationLevelId])
  @@index([tenantId])
  @@index([educationLevelId])
  @@map("tenant_stamps")
}

// Signatures électroniques des responsables : par niveau scolaire et par rôle (département administratif).
// Compound unique : where { tenantId_educationLevelId_role: { tenantId, educationLevelId, role } }
model TenantSignature {
  id               String          @id @default(uuid())
  tenantId         String
  educationLevelId String?         // null = responsable global
  role             String          // DIRECTEUR | COMPTABLE | DIRECTEUR_ADJOINT | etc.
  holderFirstName  String
  holderLastName   String
  signatureUrl     String?
  generatedAt      DateTime?
  createdAt        DateTime        @default(now())
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  educationLevel   EducationLevel? @relation(fields: [educationLevelId], references: [id], onDelete: Cascade)
  @@unique([tenantId, educationLevelId, role])
  @@index([tenantId])
  @@index([educationLevelId])
  @@map("tenant_signatures")
}

