model Staff {
  id                        String                     @id @default(uuid())
  tenantId                  String
  academicYearId            String?
  schoolLevelId             String?
  employeeNumber            String                     @unique
  /// Matricule global Academia Helm (format: AH-STF-YY-XXXXXX, unique système-wide)
  globalMatricule           String?                    @unique
  /// Matricule spécifique au tenant/école (format: <CODE>-YY-XXXXX, unique par tenant)
  tenantMatricule           String?
  firstName                 String
  lastName                  String
  gender                    String?
  dateOfBirth               DateTime?
  birthDate                 DateTime?                  @db.Date
  phone                     String?
  email                     String?
  address                   String?
  position                  String?
  department                String?
  roleType                  String                     @default("TEACHER")
  /// Langues enseignées par ce Staff (si roleType=TEACHER) : ["FR"], ["EN"], ["FR","EN"], null.
  /// Sync vers Teacher.assignedLanguages quand le Staff est lié à un Teacher.
  /// Si bilingue désactivé → ["FR"] par défaut. Si bilingue activé → ["FR","EN"] par défaut.
  assignedLanguages         Json?
  hireDate                  DateTime?
  contractType              String?
  status                    String                     @default("PENDING_SIGNATURE")
  salary                    Decimal?                   @db.Decimal(10, 2)
  bankDetails               Json?
  emergencyContact          Json?
  qualifications            String?
  notes                     String?
  /// Nationalité du collaborateur
  nationality               String?
  /// Situation matrimoniale: SINGLE, MARRIED, DIVORCED, WIDOWED, SEPARATED
  maritalStatus             String?
  /// Nombre d'enfants à charge
  numberOfChildren          Int?
  /// Numéro de pièce d'identité (CNI, passeport, etc.)
  nationalId                String?
  /// Numéro d'immatriculation CNSS (convenience field — also in EmployeeCNSS)
  cnssNumber                String?
  /// Numéro IFU (Identifiant Fiscal Unique)
  ifuNumber                 String?
  /// Type de départ: RESIGNATION, DISMISSAL, MUTUAL_AGREEMENT, END_OF_CONTRACT, RETIREMENT, DEATH, ABANDONMENT, OTHER
  terminationType              String?
  /// Détails de la résiliation/débauche (motif, préavis, entretien de sortie, etc.)
  terminationDetails           Json?
  /// Date effective de départ
  terminatedAt                 DateTime?
  /// Nombre de jours de préavis (légal ou contractuel)
  noticePeriodDays             Int?
  /// Date du dernier jour travaillé
  lastWorkingDate              DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  employeeCNSS              EmployeeCNSS?
  contracts                 Contract[]
  hrApplications            HrApplication[]
  libraryLoans              LibraryLoan[]
  overtimeRecords           OvertimeRecord[]
  payrollItems              PayrollItem[]
  salaryPayments            SalaryPayment[]
  leaveRequests             LeaveRequest[]
  staffAllowances           StaffAllowance[]
  staffSchedules            StaffSchedule[]
  oneTimeBonuses            OneTimeBonus[]
  academicYear              AcademicYear?              @relation(fields: [academicYearId], references: [id])
  schoolLevel               SchoolLevel?               @relation(fields: [schoolLevelId], references: [id])
  tenant                    Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments               StaffAssignment[]
  adminAssignments          StaffAdminAssignment[]
  attendance                StaffAttendance[]
  documents                 StaffDocument[]
  evaluations               StaffEvaluation[]
  trainings                 StaffTraining[]
  taxWithholdings           TaxWithholding[]
  transportAttendants       TransportAttendant[]
  transportDrivers          TransportDriver[]
  photo                     StaffPhoto?
  globalResourceUsages      TenantResourceUsage[]      @relation("StaffResourceUsages")
  globalResourceAnnotations TenantResourceAnnotation[] @relation("StaffResourceAnnotations")
  organigramNodes           OrganigramNode[]           @relation("StaffOrganigramNodes")
  managedDepartments        Department[]               @relation("DepartmentManager")

  @@index([tenantId])
  @@index([employeeNumber])
  @@index([globalMatricule])
  @@index([tenantMatricule])
  @@index([status])
  @@index([roleType])
  @@index([tenantId, status])
  @@index([tenantId, academicYearId])
  @@index([email, tenantId])
  @@map("staff")
}

model StaffDocument {
  id             String        @id @default(uuid())
  tenantId       String
  academicYearId String?
  schoolLevelId  String?
  staffId        String
  documentType   String
  fileName       String
  filePath       String
  fileSize       Int?
  mimeType       String?
  validated      Boolean       @default(false)
  uploadedBy     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  schoolLevel    SchoolLevel?  @relation(fields: [schoolLevelId], references: [id])
  staff          Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Catégorie de classement du document (pour organiser les documents sans mélange)
  category      String        @default("GENERAL") // IDENTITE, DIPLOMES, EXPERIENCE, ADMINISTRATIF, MEDICAL, GENERAL
  /// Description optionnelle du document
  description   String?
  /// Statut de validation: PENDING, VALIDATED, REJECTED
  validationStatus String     @default("PENDING")
  /// Date d'expiration du document (pour les documents avec validité limitée)
  expiresAt     DateTime?
  /// Identifiant de la version (permet de gérer les remplacements)
  version       Int           @default(1)

  @@index([tenantId])
  @@index([staffId])
  @@index([documentType])
  @@index([category])
  @@index([validationStatus])
  @@map("staff_documents")
}

