  @@map("fee_installments")
}

model StudentFee {
  id                 String              @id @default(uuid())
  tenantId           String
  studentId          String
  feeDefinitionId    String
  academicYearId     String
  totalAmount        Decimal             @db.Decimal(10, 2)
  status             String              @default("NOT_STARTED")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  feeArrears         FeeArrear[]
  paymentAllocations PaymentAllocation[]
  paymentSummary     PaymentSummary?
  payments           Payment[]           @relation("StudentFeePayment")
  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id])
  feeDefinition      FeeDefinition       @relation(fields: [feeDefinitionId], references: [id])
  student            Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([studentId, feeDefinitionId, academicYearId])
  @@index([tenantId, academicYearId])
  @@index([studentId])
  @@index([status])
  @@map("student_fees")
}

model PaymentAllocation {
  id              String         @id @default(uuid())
  paymentId       String
  targetType      String
  targetId        String
  studentFeeId    String?
  studentArrearId String?
  allocatedAmount Decimal        @db.Decimal(10, 2)
  allocationOrder Int
  notes           String?
  createdAt       DateTime       @default(now())
  payment         Payment        @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  studentArrear   StudentArrear? @relation("PaymentAllocationArrear", fields: [studentArrearId], references: [id], onDelete: Cascade)
  studentFee      StudentFee?    @relation(fields: [studentFeeId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([targetType, targetId])
  @@index([studentFeeId])
  @@index([studentArrearId])
  @@index([paymentId, allocationOrder])
  @@map("payment_allocations")
}

model PaymentReceipt {
  id                    String                @id @default(uuid())
  paymentId             String                @unique
  receiptNumber         String                @unique
  filePath              String?
  verificationToken     String?               @unique
  verificationTokenHash String?               @unique
  issuedAt              DateTime              @default(now())
  issuedBy              String?
  isDuplicate           Boolean               @default(false)
  duplicateOf           String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  notifications         PaymentNotification[]
  originalReceipt       PaymentReceipt?       @relation("ReceiptDuplicate", fields: [duplicateOf], references: [id])
  duplicates            PaymentReceipt[]      @relation("ReceiptDuplicate")
  issuer                User?                 @relation("PaymentReceiptIssuer", fields: [issuedBy], references: [id])
  payment               Payment               @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([receiptNumber])
  @@index([verificationTokenHash])
  @@map("payment_receipts")
}

model PaymentNotification {
  id              String         @id @default(uuid())
  paymentId       String
  receiptId       String
  channel         String
  recipientPhone  String
  messageSnapshot String
  attachmentUrl   String?
  status          String         @default("PENDING")
  sentAt          DateTime?
  errorMessage    String?
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  payment         Payment        @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  receipt         PaymentReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([receiptId])
  @@index([channel])
  @@index([status])
  @@index([sentAt])
  @@map("payment_notifications")
}

model PaymentSummary {
  id              String       @id @default(uuid())
  tenantId        String
  studentId       String
  academicYearId  String
  studentFeeId    String       @unique
  expectedAmount  Decimal      @db.Decimal(10, 2)
  paidAmount      Decimal      @default(0) @db.Decimal(10, 2)
  balance         Decimal      @default(0) @db.Decimal(10, 2)
  lastPaymentDate DateTime?
  updatedAt       DateTime     @updatedAt
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id])
  studentFee      StudentFee   @relation(fields: [studentFeeId], references: [id], onDelete: Cascade)
  student         Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId, studentFeeId])
  @@index([tenantId, academicYearId])
  @@index([studentId])
  @@map("payment_summaries")
}

/// Sous-module 2 — Statut du compte élève (spec institutionnelle).
enum AccountStatus {
  ACTIVE
  PARTIAL
  PAID
  OVERDUE
  BLOCKED
  CLOSED
}

/// Sous-module 2 — Compte financier par élève et par année. Solde calculé automatiquement (trigger).
model StudentAccount {
  id               String              @id @default(uuid())
  tenantId         String
  studentId        String
  academicYearId   String
  totalDue         Decimal             @default(0) @db.Decimal(10, 2)
  totalPaid        Decimal             @default(0) @db.Decimal(10, 2)
  balance          Decimal             @default(0) @db.Decimal(10, 2)
  arrearsAmount    Decimal             @default(0) @db.Decimal(10, 2)
  status           AccountStatus      @default(ACTIVE)
  isBlocked        Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  academicYear     AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  student          Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  breakdowns       AccountBreakdown[]
  recoveryReminders RecoveryReminder[]
  transactions     FinanceTransaction[]

  @@unique([studentId, academicYearId])
  @@index([tenantId, academicYearId])
  @@index([studentId])
  @@index([status])
  @@index([isBlocked])
  @@map("student_accounts")
}

model AccountBreakdown {
  id                String         @id @default(uuid())
  studentAccountId  String
  feeStructureId    String
  initialAmount     Decimal        @db.Decimal(10, 2)
  adjustedAmount    Decimal        @db.Decimal(10, 2)
  paidAmount        Decimal        @default(0) @db.Decimal(10, 2)
  remainingAmount   Decimal        @db.Decimal(10, 2)
  createdAt         DateTime       @default(now())
  feeStructure      FeeStructure   @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  studentAccount    StudentAccount @relation(fields: [studentAccountId], references: [id], onDelete: Cascade)
  transactionAllocations FinanceTransactionAllocation[]

  @@index([studentAccountId])
  @@index([feeStructureId])
  @@map("account_breakdowns")
}

/// Sous-module 3 — Type et moyen de paiement (spec institutionnelle).
enum TransactionType {
  PAYMENT
  REVERSAL
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  WIRE
  FEDAPAY
}

/// Sous-module 3 — Transaction d'encaissement liée au compte élève. Jamais de suppression (trigger).
model FinanceTransaction {
  id               String            @id @default(uuid())
  tenantId         String
  academicYearId   String
  studentAccountId String
  type             TransactionType
  amount           Decimal           @db.Decimal(10, 2)
  paymentMethod    PaymentMethod
  reference        String?
  reversedFromId   String?
  cashierId        String
  cashRegisterId   String?
  deviceId         String?
  receiptNumber    String          @unique
  receiptUrl       String?
  integrityHash    String?
  createdAt        DateTime        @default(now())
  academicYear     AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  reversedFrom     FinanceTransaction?  @relation("FinanceTransactionReversal", fields: [reversedFromId], references: [id], onDelete: SetNull)
  reversals        FinanceTransaction[] @relation("FinanceTransactionReversal")
  studentAccount   StudentAccount  @relation(fields: [studentAccountId], references: [id], onDelete: Cascade)
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashRegister     CashRegister?   @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)
  allocations      FinanceTransactionAllocation[]

  @@index([tenantId, academicYearId])
  @@index([studentAccountId])
  @@index([type])
  @@index([reversedFromId])
  @@index([cashRegisterId])
  @@map("finance_transactions")
}

/// Détail d'imputation par transaction (pour annulation correcte).
model FinanceTransactionAllocation {
  id                 String              @id @default(uuid())
  financeTransactionId String
  accountBreakdownId  String
  amount             Decimal             @db.Decimal(10, 2)
  financeTransaction  FinanceTransaction  @relation(fields: [financeTransactionId], references: [id], onDelete: Cascade)
  accountBreakdown   AccountBreakdown    @relation(fields: [accountBreakdownId], references: [id], onDelete: Cascade)

  @@unique([financeTransactionId, accountBreakdownId])
  @@index([financeTransactionId])
  @@index([accountBreakdownId])
  @@map("finance_transaction_allocations")
}

/// Sous-module 4 — Niveau et canal de relance (spec institutionnelle).
enum ReminderLevel {
  WARNING
  URGENT
  FINAL_NOTICE
}

enum ReminderChannel {
  SMS
  WHATSAPP
  EMAIL
}

/// Sous-module 4 — Relance recouvrement (niveaux WARNING, URGENT, FINAL_NOTICE).
model RecoveryReminder {
  id               String          @id @default(uuid())
  tenantId         String
  academicYearId   String
  studentAccountId String
  reminderLevel    ReminderLevel
  amountDue        Decimal         @db.Decimal(10, 2)
  sentVia          ReminderChannel
  sentAt           DateTime        @default(now())
  createdBySystem  Boolean         @default(true)
  academicYear     AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  studentAccount   StudentAccount @relation(fields: [studentAccountId], references: [id], onDelete: Cascade)
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, academicYearId])
  @@index([studentAccountId])
  @@index([reminderLevel])
  @@index([sentAt])
  @@map("recovery_reminders")
}

model DailyClosure {
  id             String       @id @default(uuid())
  tenantId       String
  academicYearId String
  schoolLevelId  String
  date           DateTime     @db.Date
  totalCollected Decimal      @default(0) @db.Decimal(10, 2)
  totalSpent     Decimal      @default(0) @db.Decimal(10, 2)
  openingBalance Decimal      @default(0) @db.Decimal(10, 2)
  closingBalance Decimal      @default(0) @db.Decimal(10, 2)
  discrepancy    Decimal?     @db.Decimal(10, 2)
  validated      Boolean      @default(false)
  validatedBy    String?
  validatedAt    DateTime?
  notes          String?
  createdBy      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  creator        User?        @relation("DailyClosureCreator", fields: [createdBy], references: [id])
  schoolLevel    SchoolLevel  @relation(fields: [schoolLevelId], references: [id])
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  validator      User?        @relation("DailyClosureValidator", fields: [validatedBy], references: [id])

  @@unique([tenantId, academicYearId, schoolLevelId, date])
  @@index([tenantId, academicYearId, schoolLevelId])
  @@index([date])
  @@map("daily_closures")
}

model FeeArrear {
  id              String               @id @default(uuid())
  tenantId        String
  academicYearId  String
  studentId       String
  studentFeeId    String
  totalDue        Decimal              @db.Decimal(10, 2)
  totalPaid       Decimal              @default(0) @db.Decimal(10, 2)
  balanceDue      Decimal              @db.Decimal(10, 2)
  arrearsLevel    String               @default("LOW")
  lastPaymentDate DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  actions         CollectionAction[]
  reminders       CollectionReminder[]
  academicYear    AcademicYear         @relation(fields: [academicYearId], references: [id])
  studentFee      StudentFee           @relation(fields: [studentFeeId], references: [id], onDelete: Cascade)
  student         Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promises        PaymentPromise[]

  @@unique([studentId, studentFeeId, academicYearId])
  @@index([tenantId, academicYearId])
  @@index([studentId])
  @@index([arrearsLevel])
  @@map("fee_arrears")
}

model CollectionReminder {
  id            String    @id @default(uuid())
  feeArrearId   String
  channel       String
  reminderStage String
  sentAt        DateTime  @default(now())
  status        String    @default("SENT")
  message       String?
  metadata      Json?
  createdAt     DateTime  @default(now())
  feeArrear     FeeArrear @relation(fields: [feeArrearId], references: [id], onDelete: Cascade)

  @@index([feeArrearId])
  @@index([status])
  @@index([sentAt])
  @@map("collection_reminders")
}

model PaymentPromise {
  id             String    @id @default(uuid())
  feeArrearId    String
  promisedAmount Decimal   @db.Decimal(10, 2)
  promisedDate   DateTime  @db.Date
  status         String    @default("PENDING")
  notes          String?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  creator        User?     @relation("PaymentPromiseCreator", fields: [createdBy], references: [id])
  feeArrear      FeeArrear @relation(fields: [feeArrearId], references: [id], onDelete: Cascade)

  @@index([feeArrearId])
  @@index([status])
  @@index([promisedDate])
  @@map("payment_promises")
}

model CollectionAction {
  id               String          @id @default(uuid())
  feeArrearId      String?
  collectionCaseId String?
  actionType       String
  channel          String?
  message          String?
  notes            String?
  performedBy      String?
  performedAt      DateTime        @default(now())
  createdAt        DateTime        @default(now())
  collectionCase   CollectionCase? @relation(fields: [collectionCaseId], references: [id], onDelete: Cascade)
  feeArrear        FeeArrear?      @relation(fields: [feeArrearId], references: [id], onDelete: Cascade)
  performer        User?           @relation("CollectionActionPerformer", fields: [performedBy], references: [id])

  @@index([feeArrearId])
  @@index([collectionCaseId])
  @@index([actionType])
  @@index([performedAt])
  @@map("collection_actions")
}

model CollectionCase {
  id                String             @id @default(uuid())
  tenantId          String
  studentId         String
  academicYearId    String
  totalDue          Decimal            @db.Decimal(10, 2)
  totalPaid         Decimal            @default(0) @db.Decimal(10, 2)
  outstandingAmount Decimal            @db.Decimal(10, 2)
  status            String             @default("ON_TIME")
  escalationLevel   Int                @default(0)
  lastActionAt      DateTime?
  blockedUntil      DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  actions           CollectionAction[]
  academicYear      AcademicYear       @relation("CollectionCaseAcademicYear", fields: [academicYearId], references: [id])
  student           Student            @relation("StudentCollectionCase", fields: [studentId], references: [id], onDelete: Cascade)
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId])
  @@index([tenantId, academicYearId])
  @@index([studentId])
  @@index([status])
  @@map("collection_cases")
}

model CanteenMenu {
  id             String        @id @default(uuid())
  tenantId       String
  academicYearId String
  weekNumber     Int
  weekStartDate  DateTime      @db.Date
  weekEndDate    DateTime      @db.Date
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  meals          CanteenMeal[]
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id])
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, academicYearId, weekNumber])
  @@index([tenantId, academicYearId])
  @@index([weekStartDate, weekEndDate])
  @@map("canteen_menus")
}

model CanteenMeal {
  id          String      @id @default(uuid())
  menuId      String
  dayOfWeek   Int
  mealType    String
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  menu        CanteenMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([menuId])
  @@index([dayOfWeek, mealType])
  @@map("canteen_meals")
}

model CanteenEnrollment {
  id             String              @id @default(uuid())
  tenantId       String
  academicYearId String
  studentId      String
  schoolLevelId  String?
  classId        String?
  startDate      DateTime            @db.Date
  endDate        DateTime?           @db.Date
  mealTypes      String[]
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  allergies      CanteenAllergy[]
  attendances    CanteenAttendance[]
  academicYear   AcademicYear        @relation(fields: [academicYearId], references: [id])
  class          Class?              @relation("CanteenEnrollmentClass", fields: [classId], references: [id])
  schoolLevel    SchoolLevel?        @relation("CanteenEnrollmentSchoolLevel", fields: [schoolLevelId], references: [id])
  student        Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, academicYearId, studentId])
  @@index([tenantId, academicYearId])
  @@index([studentId])
  @@index([isActive])
  @@map("canteen_enrollments")
}

model CanteenAttendance {
  id           String            @id @default(uuid())
  enrollmentId String
  mealDate     DateTime          @db.Date
  mealType     String
  status       String            @default("PRESENT")
  notes        String?
  recordedBy   String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  enrollment   CanteenEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  recorder     User?             @relation("CanteenAttendanceRecorder", fields: [recordedBy], references: [id])

  @@unique([enrollmentId, mealDate, mealType])
  @@index([enrollmentId])
  @@index([mealDate])
  @@index([status])
  @@map("canteen_attendances")
}

model CanteenAllergy {
  id           String            @id @default(uuid())
  enrollmentId String
  allergen     String
  severity     String            @default("MODERATE")
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  enrollment   CanteenEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@index([allergen])
  @@map("canteen_allergies")
}

model Vehicle {
  id              String                @id @default(uuid())
  tenantId        String
  academicYearId  String
  vehicleType     String
  plateNumber     String
  capacity        Int
  driverId        String?
  status          String                @default("ACTIVE")
  lastMaintenance DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  routes          Route[]
  assignments     TransportAssignment[]
  incidents       TransportIncident[]
  academicYear    AcademicYear          @relation(fields: [academicYearId], references: [id])
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, academicYearId, plateNumber])
  @@index([tenantId, academicYearId])
  @@index([status])
  @@map("vehicles")
}

model Route {
  id             String                @id @default(uuid())
  tenantId       String
  academicYearId String
  vehicleId      String
  name           String
  description    String?
  startTime      String
  endTime        String?
  isActive       Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  stops          RouteStop[]
  academicYear   AcademicYear          @relation(fields: [academicYearId], references: [id])
  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle        Vehicle               @relation(fields: [vehicleId], references: [id])
  assignments    TransportAssignment[]
  incidents      TransportIncident[]

  @@index([tenantId, academicYearId])
  @@index([vehicleId])
  @@index([isActive])
  @@map("routes")
}

model RouteStop {
  id          String                @id @default(uuid())
  routeId     String
  stopOrder   Int
  name        String
  address     String?
  latitude    Decimal?              @db.Decimal(10, 8)
  longitude   Decimal?              @db.Decimal(11, 8)
  arrivalTime String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  route       Route                 @relation(fields: [routeId], references: [id], onDelete: Cascade)
  assignments TransportAssignment[]

  @@index([routeId])
  @@index([routeId, stopOrder])
  @@map("route_stops")
}

model TransportAssignment {
  id             String                @id @default(uuid())
  tenantId       String
  academicYearId String
  studentId      String
  routeId        String
  vehicleId      String
  stopId         String?
  startDate      DateTime              @db.Date
  endDate        DateTime?             @db.Date
  isActive       Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  academicYear   AcademicYear          @relation(fields: [academicYearId], references: [id])
  route          Route                 @relation(fields: [routeId], references: [id])
  stop           RouteStop?            @relation(fields: [stopId], references: [id])
  student        Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle        Vehicle               @relation(fields: [vehicleId], references: [id])
  attendances    TransportAttendance[]

  @@unique([tenantId, academicYearId, studentId])
  @@index([tenantId, academicYearId])
  @@index([studentId])
  @@index([routeId])
  @@index([vehicleId])
  @@index([isActive])
  @@map("transport_assignments")
}

model TransportAttendance {
  id             String              @id @default(uuid())
  assignmentId   String
  attendanceDate DateTime            @db.Date
  direction      String
  status         String              @default("PRESENT")
  notes          String?
  recordedBy     String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  assignment     TransportAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  recorder       User?               @relation("TransportAttendanceRecorder", fields: [recordedBy], references: [id])

  @@unique([assignmentId, attendanceDate, direction])
  @@index([assignmentId])
  @@index([attendanceDate])
  @@index([status])
  @@map("transport_attendances")
}

model TransportIncident {
  id               String       @id @default(uuid())
  tenantId         String
  academicYearId   String
  vehicleId        String?
  routeId          String?
  incidentDate     DateTime     @db.Date
  incidentType     String
  severity         String       @default("MEDIUM")
  description      String
  affectedStudents Int?
  resolved         Boolean      @default(false)
  resolvedAt       DateTime?
  reportedBy       String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  academicYear     AcademicYear @relation(fields: [academicYearId], references: [id])
  reporter         User?        @relation("TransportIncidentReporter", fields: [reportedBy], references: [id])
  route            Route?       @relation(fields: [routeId], references: [id])
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle          Vehicle?     @relation(fields: [vehicleId], references: [id])

  @@index([tenantId, academicYearId])
  @@index([vehicleId])
  @@index([routeId])
  @@index([incidentDate])
  @@index([severity])
  @@index([resolved])
  @@map("transport_incidents")
}

model LibraryBook {
