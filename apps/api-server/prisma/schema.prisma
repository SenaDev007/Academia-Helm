  academicYear  AcademicYear               @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  tenant        Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([schoolYearId])
  @@index([tenantId, schoolYearId])
  @@index([countryCode])
  @@index([status])
  @@index([isActive])
  @@map("school_academic_settings")
}

