/// Périodes académiques (trimestres, semestres, séquences) — une année en contient plusieurs.
/// Une seule période active à la fois. Clôture = blocage modification notes/absences.
model AcademicPeriod {
  id              String       @id @default(uuid())
  tenantId        String
  academicYearId  String
  name            String
  type            AcademicPeriodType
  periodOrder     Int
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean      @default(false)
  isClosed        Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([academicYearId, periodOrder])
  @@index([tenantId, academicYearId])
  @@index([academicYearId, isActive])
  @@map("academic_periods")
}

// ============================================================================
// STRUCTURE PÉDAGOGIQUE HIÉRARCHIQUE (niveau → cycle → grade → classe physique)
// ============================================================================

/// Niveau d'enseignement : MATERNELLE, PRIMAIRE, SECONDAIRE. Activables par l'établissement.
model EducationLevel {
  id               String            @id @default(uuid())
  tenantId         String
  name             String            // MATERNELLE | PRIMAIRE | SECONDAIRE
  isEnabled        Boolean           @default(true)
  order            Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cycles           EducationCycle[]
  tenantStamps     TenantStamp[]
  tenantSignatures TenantSignature[]

  @@unique([tenantId, name])
  @@map("education_levels")
}

/// Cycle sous un niveau (ex. Maternelle 1/2 pour Maternelle - Educmaster Bénin, CE1-CM2 pour Primaire).
model EducationCycle {
  id        String   @id @default(uuid())
  levelId   String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  level     EducationLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)
  grades    EducationGrade[]

  @@unique([levelId, name])
  @@index([levelId])
  @@map("education_cycles")
}

/// Série du 2nd cycle secondaire (Bénin) : A1, A2, B, C, D. Optionnelle sur un grade.
model EducationSeries {
  id        String   @id @default(uuid())
  tenantId  String
  code      String   // A1, A2, B, C, D
  name      String?  // libellé optionnel (ex. "Série scientifique")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  grades    EducationGrade[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("education_series")
}

/// Classe pédagogique (ex. CE1, 6ème, Terminale C). Peut être liée à une série (2nd cycle secondaire).
model EducationGrade {
  id         String   @id @default(uuid())
  cycleId    String
  seriesId   String?  // optionnel : 2nd cycle secondaire (série A1, A2, B, C, D)
  name       String
  code       String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  cycle      EducationCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  series     EducationSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  classrooms Classroom[]

  @@unique([cycleId, code])
  @@index([cycleId])
  @@index([seriesId])
  @@map("education_grades")
}

/// Classe physique (ex. CE1 A, 6ème 2). Créée par l'école, liée à une année scolaire. Désactivation uniquement, pas de suppression.
model Classroom {
  id              String       @id @default(uuid())
  tenantId        String
  academicYearId  String
  gradeId         String
  name            String       // CE1 A, 6ème 2
  code            String?
  capacity        Int?
  isActive        Boolean      @default(true)
  isArchived      Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  grade           EducationGrade @relation(fields: [gradeId], references: [id], onDelete: Restrict)

  @@unique([tenantId, academicYearId, name])
  @@index([tenantId, academicYearId])
  @@index([gradeId])
  @@map("classrooms")
}

// ============================================================================
// MODULE 2 — STRUCTURE ACADÉMIQUE (niveau → cycle → classe, par année scolaire)
// ============================================================================

/// Niveau scolaire : Maternelle / Primaire / Secondaire (par année).
model AcademicLevel {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId  String
  name            String   // Maternelle | Primaire | Secondaire
  orderIndex      Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation("TenantPedagogyLevels", fields: [tenantId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  cycles          AcademicCycle[]
  classes         AcademicClass[]
  series          AcademicSeries[]
  teacherLevelAuthorizations TeacherLevelAuthorization[]

  @@unique([tenantId, academicYearId, name])
  @@index([tenantId, academicYearId])
  @@map("pedagogy_academic_levels")
}

/// Cycle : PS/MS/GS, CI-CM2, 6ème-Terminale (par niveau, par année).
model AcademicCycle {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId  String
  levelId         String
  name            String   // PS, MS, GS, CI, CP, 6ème, etc.
  orderIndex      Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation("TenantPedagogyCycles", fields: [tenantId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  level           AcademicLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)
  classes         AcademicClass[]

  @@unique([tenantId, academicYearId, levelId, name])
  @@index([tenantId, academicYearId])
  @@index([levelId])
  @@map("pedagogy_academic_cycles")
}

/// Classe pédagogique (ex. CM2 A, 6ème B). Par année, avec salle et responsable.
model AcademicClass {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId  String
  levelId         String
  cycleId         String
  name            String   // "CM2 A", "6ème B"
  code            String   // CM2A, 6EMEB
  capacity        Int?
  roomId          String?
  mainTeacherId   String?
  languageTrack   String?  // FR | EN si bilingue
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation("TenantPedagogyClasses", fields: [tenantId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  level           AcademicLevel @relation(fields: [levelId], references: [id], onDelete: Restrict)
  cycle           AcademicCycle @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  room            Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  mainTeacher     Teacher? @relation("AcademicClassMainTeacher", fields: [mainTeacherId], references: [id], onDelete: SetNull)
  teachingAssignments TeachingAssignment[]

  @@unique([tenantId, academicYearId, code])
  @@index([tenantId, academicYearId])
  @@index([levelId])
  @@index([cycleId])
  @@index([roomId])
  @@map("pedagogy_academic_classes")
}

// ============================================================================
// MODULE 2 — MATIÈRES & PROGRAMMES (séries secondaire, programmes officiels)
// ============================================================================

/// Série secondaire (A, C, D, G2…). Uniquement pour niveau Secondaire.
model AcademicSeries {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId   String
  levelId         String
  name            String   // A, C, D, G2
  description     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation("TenantPedagogySeries", fields: [tenantId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  level           AcademicLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)
  seriesSubjects  SeriesSubject[]
  teachingAssignments TeachingAssignment[]

  @@unique([tenantId, academicYearId, levelId, name])
  @@index([tenantId, academicYearId])
  @@index([levelId])
  @@map("pedagogy_academic_series")
}

/// Matière par série (coefficient + volume horaire).
model SeriesSubject {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId   String
  seriesId        String
  subjectId       String
  coefficient     Int
  weeklyHours     Int
  createdAt       DateTime @default(now())
  tenant          Tenant   @relation("TenantSeriesSubjects", fields: [tenantId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  series          AcademicSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  subject         Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([seriesId, subjectId])
  @@index([tenantId, academicYearId])
  @@index([seriesId])
  @@index([subjectId])
  @@map("pedagogy_series_subjects")
}

/// Programme officiel (PDF) attaché à une matière, versionné.
model SubjectProgram {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId   String
  subjectId       String
  documentUrl     String
  version         String
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  tenant          Tenant   @relation("TenantSubjectPrograms", fields: [tenantId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  subject         Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([tenantId, academicYearId])
  @@index([subjectId])
  @@map("pedagogy_subject_programs")
}

// ============================================================================
// MODULE 2 — SOUS-MODULES 3 à 8 (Enseignants académiques, Affectations, EDT, Espace pédago, Contrôle, ORION)
// ============================================================================

/// Profil académique enseignant (charge max, statut pédagogique) — SM3
model TeacherAcademicProfile {
  id               String   @id @default(uuid())
  tenantId         String
  academicYearId   String
