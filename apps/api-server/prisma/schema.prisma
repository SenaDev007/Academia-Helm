/// Sous-module 5 — Statut dépense (workflow validation).
enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Sous-module 5 — Dépense institutionnelle (workflow, justificatif, budget).
model FinanceExpense {
  id               String        @id @default(uuid())
  tenantId         String
  academicYearId   String
  categoryId       String
  amount           Decimal       @db.Decimal(12, 2)
  description      String
  receiptUrl       String?
  status           ExpenseStatus @default(PENDING)
  requestedById    String
  approvedById     String?
  approvedAt       DateTime?
  createdAt        DateTime      @default(now())
  academicYear     AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  category         ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requester        User          @relation("FinanceExpenseRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  approver         User?         @relation("FinanceExpenseApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([tenantId, academicYearId])
  @@index([categoryId])
  @@index([status])
  @@map("finance_expenses")
}

/// Sous-module 5 — Budget annuel par catégorie (Dépenses & Budget).
model FinanceBudget {
  id               String         @id @default(uuid())
  tenantId         String
  academicYearId   String
  categoryId       String
  allocatedAmount  Decimal        @db.Decimal(12, 2)
  createdAt        DateTime       @default(now())
  academicYear     AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  category         ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, academicYearId, categoryId])
  @@index([tenantId, academicYearId])
  @@map("finance_budgets")
}

/// Sous-module 6 — Clôture journalière (date unique tenant + année). Calcul auto, type MANUAL/AUTO, anomalie.
enum ClosureType {
  MANUAL
  AUTO
}

model FinanceDailyClosure {
  id               String         @id @default(uuid())
  tenantId         String
  academicYearId   String
  date             DateTime       @db.Date
  totalIncome      Decimal        @db.Decimal(12, 2)
  totalExpense     Decimal        @db.Decimal(12, 2)
  netBalance       Decimal        @db.Decimal(12, 2)
  closureType      ClosureType    @default(MANUAL)
  validatedById    String?
  validatedAt      DateTime?
  anomalyDetected  Boolean        @default(false)
  anomalyNote      String?
  physicalAmount   Decimal?       @db.Decimal(12, 2)
  discrepancy      Decimal?       @db.Decimal(12, 2)
  createdAt        DateTime       @default(now())
  academicYear     AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  validator        User?          @relation("FinanceDailyClosureValidator", fields: [validatedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, academicYearId, date])
  @@index([tenantId, academicYearId])
  @@index([date])
  @@map("finance_daily_closures")
}

/// Sous-module 7 — Log des exports de rapports financiers.
