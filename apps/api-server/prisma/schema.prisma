model PublicVerificationToken {
  id                String       @id @default(uuid())
  tenantId          String
  entityType        String       @default("STUDENT")
  entityId          String
  tokenHash         String       @unique
  token             String       @unique
  academicYearId    String
  expiresAt         DateTime
  isActive          Boolean      @default(true)
  verificationCount Int          @default(0)
  lastVerifiedAt    DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  academicYear      AcademicYear @relation(fields: [academicYearId], references: [id])
  student           Student      @relation("PublicVerificationTokenStudent", fields: [entityId], references: [id], onDelete: Cascade)
  tenant            Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  verificationLogs  PublicVerificationLog[]

  @@unique([tenantId, academicYearId, entityId])
  @@index([tokenHash])
  @@index([entityId, academicYearId])
  @@index([expiresAt, isActive])
  @@map("public_verification_tokens")
}

/// Journal des vérifications publiques (scan QR carte scolaire) — rate limiting, audit, pas d'info sensible
