model Meeting {
  id              String                @id @default(uuid())
  tenantId        String
  academicYearId  String
  meetingType     String
  scopeType       String
  schoolLevelId   String?
  classId         String?
  studentId       String?
  title           String
  description     String?
  meetingDate     DateTime              @db.Date
  startTime       String?
  endTime         String?
  location        String?
  locationOnline  Boolean               @default(false)
  meetingLink     String?
  status          String                @default("PLANNED")
  cancelledAt     DateTime?
  cancelledBy     String?
  cancelledReason String?
  createdBy       String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  agendas         MeetingAgenda[]
  attachments     MeetingAttachment[]
  decisions       MeetingDecision[]
  minutes         MeetingMinutes?
  notifications   MeetingNotification[]
  participants    MeetingParticipant[]
  academicYear    AcademicYear          @relation(fields: [academicYearId], references: [id])
  cancelledByUser User?                 @relation("MeetingCancelledBy", fields: [cancelledBy], references: [id])
  class           Class?                @relation("MeetingClass", fields: [classId], references: [id])
  creator         User?                 @relation("MeetingCreator", fields: [createdBy], references: [id])
  schoolLevel     SchoolLevel?          @relation("MeetingSchoolLevel", fields: [schoolLevelId], references: [id])
  student         Student?              @relation("MeetingStudent", fields: [studentId], references: [id])
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, academicYearId])
  @@index([meetingType])
  @@index([scopeType])
  @@index([schoolLevelId])
  @@index([classId])
  @@index([studentId])
  @@index([status])
  @@index([meetingDate])
  @@map("meetings")
}

model MeetingParticipant {
  id               String    @id @default(uuid())
  meetingId        String
  participantType  String
  participantId    String
  invitedAt        DateTime  @default(now())
  invitedBy        String?
  attendanceStatus String?
  attendanceTime   DateTime?
  excuseReason     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  inviter          User?     @relation("MeetingParticipantInviter", fields: [invitedBy], references: [id])
  meeting          Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, participantType, participantId])
  @@index([meetingId])
  @@index([participantType, participantId])
  @@index([attendanceStatus])
  @@map("meeting_participants")
}

model MeetingAgenda {
  id              String   @id @default(uuid())
  meetingId       String
  agendaOrder     Int      @default(0)
  topic           String
  description     String?
  presenterId     String?
  durationMinutes Int?
  status          String   @default("PLANNED")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  meeting         Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  presenter       User?    @relation("MeetingAgendaPresenter", fields: [presenterId], references: [id])

  @@index([meetingId])
  @@index([meetingId, agendaOrder])
  @@map("meeting_agendas")
}

model MeetingMinutesTemplate {
  id          String                  @id @default(uuid())
  tenantId    String?
  meetingType String
  name        String
  description String?
  template    String
  structure   Json?
  isSystem    Boolean                 @default(false)
  isActive    Boolean                 @default(true)
  language    String                  @default("FR")
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  minutes     MeetingMinutes[]
  tenant      Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions    MeetingMinutesVersion[]

  @@index([tenantId, meetingType])
  @@index([isSystem])
  @@index([isActive])
  @@map("meeting_minutes_templates")
}

model MeetingMinutes {
  id              String                  @id @default(uuid())
  meetingId       String                  @unique
  templateId      String?
  version         Int                     @default(1)
  content         String
  renderedContent String?
  pdfPath         String?
  language        String                  @default("FR")
  recordedBy      String?
  recordedAt      DateTime?
  validatedBy     String?
  validatedAt     DateTime?
  validated       Boolean                 @default(false)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  signatures      ElectronicSignature[]
  meeting         Meeting                 @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  recorder        User?                   @relation("MeetingMinutesRecorder", fields: [recordedBy], references: [id])
  template        MeetingMinutesTemplate? @relation(fields: [templateId], references: [id])
  validator       User?                   @relation("MeetingMinutesValidator", fields: [validatedBy], references: [id])
  history         MeetingMinutesVersion[]

  @@index([meetingId])
  @@index([templateId])
  @@index([validated])
  @@index([language])
  @@index([version])
  @@map("meeting_minutes")
}

model MeetingMinutesVersion {
  id              String                  @id @default(uuid())
  minutesId       String
  templateId      String?
  version         Int
  content         String
  renderedContent String?
  pdfPath         String?
  changes         String?
  modifiedBy      String?
  modifiedAt      DateTime                @default(now())
  validatedBy     String?
  validatedAt     DateTime?
  minutes         MeetingMinutes          @relation(fields: [minutesId], references: [id], onDelete: Cascade)
  modifier        User?                   @relation("MeetingMinutesVersionModifier", fields: [modifiedBy], references: [id])
  template        MeetingMinutesTemplate? @relation(fields: [templateId], references: [id])
  validator       User?                   @relation("MeetingMinutesVersionValidator", fields: [validatedBy], references: [id])

  @@index([minutesId])
  @@index([version])
  @@index([modifiedAt])
  @@map("meeting_minutes_versions")
}

model ElectronicSignature {
  id            String         @id @default(uuid())
  minutesId     String
  userId        String
  signatureType String         @default("VALIDATION")
  signatureHash String
  signatureData String?
  ipAddress     String?
  userAgent     String?
  signedAt      DateTime       @default(now())
  createdAt     DateTime       @default(now())
  minutes       MeetingMinutes @relation(fields: [minutesId], references: [id], onDelete: Cascade)
  user          User           @relation("ElectronicSignatureUser", fields: [userId], references: [id])

  @@unique([minutesId, userId, signatureType])
  @@index([minutesId])
  @@index([userId])
  @@index([signedAt])
  @@map("electronic_signatures")
}

model MeetingDecision {
  id              String    @id @default(uuid())
  meetingId       String
  decisionText    String
  decisionOrder   Int       @default(0)
  responsibleId   String?
  dueDate         DateTime?
  status          String    @default("PENDING")
  completionDate  DateTime?
  completionNotes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  meeting         Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  responsible     User?     @relation("MeetingDecisionResponsible", fields: [responsibleId], references: [id])

  @@index([meetingId])
  @@index([responsibleId])
  @@index([status])
  @@index([dueDate])
  @@map("meeting_decisions")
}

model MeetingAttachment {
  id         String   @id @default(uuid())
  meetingId  String
  fileName   String
  filePath   String
  fileSize   Int?
  fileType   String?
