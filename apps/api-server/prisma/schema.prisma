/// Configuration académique d'évaluation pour un établissement, une année scolaire et un profil.
/// Contient toutes les règles : types d'évaluations, formules de calcul, bulletins, passage, classements.
model SchoolAcademicSettings {
  id            String                     @id @default(uuid())
  tenantId      String
  schoolYearId  String
  /// Profil pays/système (ex: BENIN_NATIONAL, CAMEROUN_FRANCOPHONE, CUSTOM)
  countryCode   String
  systemCode    String?
  cycleCode     String?
  levelCode     String?
  classId       String?
  name          String
  description   String?
  status        AcademicSettingsStatus     @default(DRAFT)
  version       Int                        @default(1)
  isActive      Boolean                    @default(false)
  isLocked      Boolean                    @default(false)
  /// Configuration académique complète (JSON flexible):
  /// { country, system, cycle, periodType, gradingMode, scoreScale,
  /// assessmentTypes, calculationRules, rankingRules, promotionRules,
  /// gradingScale, reportCard }
  config        Json
  createdById   String?
  activatedById String?
  lockedById    String?
  activatedAt   DateTime?
  lockedAt      DateTime?
  archivedAt    DateTime?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
