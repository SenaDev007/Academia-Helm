# --- Déploiement (Netlify, Vercel, etc.) ---
# À définir dans l'UI du provider (Build + Runtime). Sans slash final pour l'URL app.
# NEXT_PUBLIC_APP_URL=https://votre-site.netlify.app
# Alternative : NEXT_PUBLIC_BASE_DOMAIN=votre-domaine.com
# NEXT_PUBLIC_API_URL=https://votre-api.example.com/api
# NEXT_PUBLIC_API_DOMAIN= (optionnel si l'API est sur un autre host)
# URL du site public (landing page) — utilisée par le bouton "Visiter le site" dans l'app
# Si non définie, le code tente de déduire l'URL en retirant le sous-domaine.
# ⚠️ En production, le domaine racine peut ne pas être accessible via DNS.
#     Définir cette variable avec l'URL qui fonctionne réellement.
# NEXT_PUBLIC_LANDING_URL=https://www.votre-domaine.com

# ─── AI Configuration (Modal / OpenRouter) ───
# Clé API pour les IA intégrées (Orion, Atlas, Sara, HDIE, SCE)
# Modal (gratuit, recommandé) ou OpenRouter (payant)
OPENROUTER_API_KEY=
# Modèle à utiliser (défaut: zai-org/GLM-5.1-FP8 — Modal GLM-5.1 FP8)
# Options Modal : zai-org/GLM-5.1-FP8, zai-org/GLM-5-FP8
# Options OpenRouter : z-ai/glm-5.1, z-ai/glm-4.5-air:free
OPENROUTER_MODEL=zai-org/GLM-5.1-FP8
# URL de base (défaut: https://api.us-west-2.modal.direct/v1 pour Modal)
# Pour OpenRouter : https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=https://api.us-west-2.modal.direct/v1

# ─── Orion LLM Configuration ───
# Provider LLM pour ORION : openrouter (défaut) | openai | anthropic | local
ORION_LLM_PROVIDER=openrouter
# Modèle LLM pour ORION (défaut: zai-org/GLM-5.1-FP8)
ORION_LLM_MODEL=zai-org/GLM-5.1-FP8

# ─── Anthropic (legacy, optionnel) ───
ANTHROPIC_API_KEY=
# Optionnel (défaut: claude-sonnet-4-20250514)
ANTHROPIC_MODEL=

# SerpAPI / analyse concurrents (optionnel mais recommandé)
SERPER_API_KEY=
# Domaine à suivre dans les SERP (ex: academiahelm.com)
SEO_TRACK_DOMAIN=academiahelm.com

# Upstash Redis (leads + rank tracking)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Cloudflare Turnstile (vérification d'humanité) ───
# Clé publique (côté client) — obtenue depuis le dashboard Cloudflare → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Clé secrète (côté serveur uniquement) — pour vérifier le token
TURNSTILE_SECRET_KEY=

# Publication automatique
SEO_ARTICLES_PER_DAY=3
