# Vercel / build production — URL du backend Nest (sans /api final ; normalisé dans le code)
NEXT_PUBLIC_API_URL=https://api.academiahelm.com

# URL interne pour les appels serveur-à-serveur (BFF → API) — contourne Cloudflare
# ⚠️ OBLIGATOIRE en production Vercel : Cloudflare Managed Challenge bloque les requêtes
#     venant des data centers Vercel (IPs cloud). L'URL interne permet de contourner
#     le proxy Cloudflare en appelant directement Railway.
#
# Valeur : URL Railway directe (sans /api final)
#   API_INTERNAL_URL=https://8nvfmrrz.up.railway.app
#
# Le BFF envoie automatiquement le header Host: api.academiahelm.com pour que
# Railway route correctement la requête vers l'application NestJS.
#
# Configuration dans Vercel :
#   1. Aller dans Settings > Environment Variables du projet web-app
#   2. Ajouter : API_INTERNAL_URL = https://8nvfmrrz.up.railway.app
#   3. Redéployer
#
# Si non définie, le BFF utilise NEXT_PUBLIC_API_URL (qui passe par Cloudflare)
# et peut être bloqué par le Managed Challenge.
# API_INTERNAL_URL=https://8nvfmrrz.up.railway.app

# URL publique de l'application (nécessaire pour SEO, metadata, et URLs de vérification)
NEXT_PUBLIC_APP_URL=https://academiahelm.com

# Domaine de base pour le multi-tenant (sous-domaines : ecole.academiahelm.com)
NEXT_PUBLIC_BASE_DOMAIN=academiahelm.com

# URL du site public / landing page (depuis l'app, bouton "Visiter le site")
# Optionnel : si non définie, getLandingPageUrl() déduit l'URL en retirant le sous-domaine.
# ⚠️ Ne définir cette variable QUE si le domaine racine n'est pas accessible via DNS.
#     Ex: NEXT_PUBLIC_LANDING_URL=https://www.academiahelm.com
# NEXT_PUBLIC_LANDING_URL=https://www.academiahelm.com

# ─── AI Configuration (Modal / OpenRouter) ───
# Clé API pour les IA intégrées (Orion, Atlas, Sara, HDIE, SCE)
# Modal (gratuit, recommandé) ou OpenRouter (payant)
OPENROUTER_API_KEY=
# Modèle à utiliser (défaut: zai-org/GLM-5.1-FP8 — Modal GLM-5.1 FP8)
OPENROUTER_MODEL=zai-org/GLM-5.1-FP8
# URL de base (défaut: https://api.us-west-2.modal.direct/v1 pour Modal)
# Pour OpenRouter : https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=https://api.us-west-2.modal.direct/v1

# ─── Orion LLM Configuration ───
ORION_LLM_PROVIDER=openrouter
ORION_LLM_MODEL=zai-org/GLM-5.1-FP8
