# Vercel / build production — URL du backend Nest (sans /api final ; normalisé dans le code)
NEXT_PUBLIC_API_URL=https://api.academiahelm.com

# URL interne pour les appels serveur-à-serveur (BFF → API) — contourne Cloudflare
# Si non définie, le BFF utilise NEXT_PUBLIC_API_URL (qui passe par Cloudflare).
# Pour désactiver le proxy Cloudflare sur les appels serveur, définissez cette variable
# dans les paramètres Vercel du projet web-app :
#   API_INTERNAL_URL=https://<api-vercel-direct-url>
# ou si le proxy Cloudflare est désactivé (DNS only), laissez vide.
# API_INTERNAL_URL=

# URL publique de l'application (nécessaire pour SEO, metadata, et URLs de vérification)
NEXT_PUBLIC_APP_URL=https://academiahelm.com

# Domaine de base pour le multi-tenant (sous-domaines : ecole.academiahelm.com)
NEXT_PUBLIC_BASE_DOMAIN=academiahelm.com

# ─── OpenRouter AI Configuration ───
# Configurez OPENROUTER_API_KEY dans Vercel (pas dans le repo)
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=z-ai/glm-4.5-air:free

# ─── Orion LLM Configuration ───
ORION_LLM_PROVIDER=openrouter
ORION_LLM_MODEL=z-ai/glm-4.5-air:free
