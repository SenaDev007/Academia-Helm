# Vercel / build production — URL du backend Nest (sans /api final ; normalisé dans le code)
NEXT_PUBLIC_API_URL=https://api.academiahelm.com

# ─── OpenRouter AI Configuration ───
# Configurez OPENROUTER_API_KEY dans Vercel (pas dans le repo)
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=z-ai/glm-4.5-air:free

# ─── Orion LLM Configuration ───
ORION_LLM_PROVIDER=openrouter
ORION_LLM_MODEL=z-ai/glm-4.5-air:free
