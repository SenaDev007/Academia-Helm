{
  "name": "@academia-hub/web-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001 --webpack",
    "dev:turbo": "next dev -p 3001",
    "build": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" next build",
    "build:webpack": "cross-env NODE_OPTIONS=\"--max-old-space-size=6144\" next build --webpack",
    "analyze": "cross-env ANALYZE=true NODE_OPTIONS=\"--max-old-space-size=6144\" next build --webpack",
    "start": "next start -p 3001",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "optimize-images": "node scripts/optimize-images.js",
    "check-seo": "node scripts/check-seo.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "prebuild": "if [ -z \"$VERCEL\" ]; then npm run optimize-images || true; fi",
    "lighthouse": "lighthouse ${NEXT_PUBLIC_APP_URL:-http://localhost:3001} --view --output=html --output-path=./lighthouse-report.html",
    "seo:generate-article": "npx --yes tsx scripts/generate-articles.ts",
    "seo:auto-publish": "npx --yes tsx scripts/auto-publish.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@base-ui/react": "^1.3.0",
    "@clerk/nextjs": "^7.0.7",
    "@hookform/resolvers": "^5.2.2",
    "@jest/globals": "^30.4.1",
    "@marsidev/react-turnstile": "^1.5.3",
    "@radix-ui/react-slot": "^1.2.5",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/nextjs": "^10.46.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.95.2",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/pm": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "@upstash/redis": "^1.37.0",
    "axios": "^1.7.2",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.23",
    "lucide-react": "^0.542.0",
    "next": "^16.2.1",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "shadcn": "^4.1.1",
    "sharp": "^0.34.5",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^3.23.8",
    "zustand": "^5.0.12",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@netlify/plugin-nextjs": "^5.15.9",
    "@next/bundle-analyzer": "^16.2.7",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "chokidar": "^5.0.0",
    "critters": "^0.0.23",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "glob": "^13.0.0",
    "lighthouse": "^13.0.1",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
