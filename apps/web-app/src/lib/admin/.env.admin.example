# ─── Admin Back-Office Authentication ───────────────────────────────────────
#
# Variables d'environnement pour le système d'authentification SÉPARÉ du
# back-office Academia Helm (admin.academiahelm.com).
#
# Ce système est INDEPENDANT de l'authentification tenant (login normal).
# Il utilise son propre cookie `academia_admin_session` et son propre flow :
#   1. Google OAuth (recommandé) OU email/password (optionnel)
#   2. 2FA : OTP 6 chiffres envoyé par email
#   3. Session admin 12h (httpOnly, secure, sameSite=strict)
#
# Toutes ces variables sont OBLIGATOIRES pour activer le back-office.

# Liste blanche d'emails admin (séparés par virgules, minuscules).
# SEULS ces emails peuvent accéder au back-office.
# Exemple : ADMIN_EMAILS=founder@academiahelm.com,cto@academiahelm.com
ADMIN_EMAILS=

# Secret pour signer les sessions admin (HMAC SHA-256).
# Doit être différent de JWT_SECRET (qui signe les sessions tenant).
# Générer avec : openssl rand -hex 32
ADMIN_JWT_SECRET=

# ─── Google OAuth (recommandé) ─────────────────────────────────────────────
#
# Obtenir ces identifiants sur https://console.cloud.google.com/apis/credentials
# Créer un OAuth 2.0 Client ID de type "Web application".
# Authorized redirect URI : https://admin.academiahelm.com/admin-login
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://admin.academiahelm.com/admin-login

# ─── Email/password (optionnel, secours si Google indisponible) ─────────────
#
# Format JSON : { "email@exemple.com": "$2b$10$...hash-bcrypt..." }
# Pour générer un hash bcrypt : node -e "console.log(require('bcryptjs').hashSync('mon-password', 10))"
# Si non défini, seul Google Sign-In est disponible.
# ADMIN_PASSWORDS={"admin@academiahelm.com":"$2b$10$..."}

# ─── Note importante ────────────────────────────────────────────────────────
#
# L'envoi de l'OTP par email en production passe par l'API backend NestJS
# (endpoint POST /admin-auth/send-otp). Vérifier que :
#   - NEXT_PUBLIC_API_URL est défini (déjà le cas pour le reste de l'app)
#   - L'endpoint /admin-auth/send-otp est implémenté côté NestJS
#   - nodemailer / Resend est configuré côté backend
#
# En développement (NODE_ENV=development), l'OTP est loggé dans la console
# (pas d'envoi réel).
