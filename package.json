{
  "name": "academia-hub",
  "version": "1.0.0",
  "description": "Academia Hub - Web SaaS Platform (Monorepo)",
  "author": "YEHI OR Tech <yehiortech@gmail.com>",
  "private": true,
  "scripts": {
    "start:dev": "bash start-dev.sh",
    "start:dev:win": "start-dev.bat",
    "start:api": "cd apps/api-server && npm run start:dev",
    "start:frontend": "cd apps/web-app && npm run dev",
    "start:docker": "docker compose -f docker-compose.dev.yml up",
    "start:docker:detached": "docker compose -f docker-compose.dev.yml up -d",
    "stop:docker": "docker compose -f docker-compose.dev.yml down",
    "logs:docker": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:prod:build": "docker compose -f docker-compose.prod.yml build",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "migrate:sqlite-to-postgresql": "ts-node database/migrations/sqlite-to-postgresql-migration.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0"
  }
}
